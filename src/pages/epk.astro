---
// Electronic Press Kit — for promoters and booking agents.
// Protected by Cloudflare Access (enforced in src/middleware/index.ts); noindex
// keeps it out of search even if the Access app is misconfigured.
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { getEvents } from '../lib/content';
import {
  EPK_BIO,
  EPK_CONTACTS,
  EPK_FEATURED_VIDEO,
  EPK_HOSPITALITY,
  EPK_PHOTOS,
  EPK_TECH_RIDER,
  epkStats,
} from '../lib/epk';

const db = (Astro.locals as any).runtime?.env?.DB;
const { upcoming, past } = await getEvents(db);
const stats = epkStats([...upcoming, ...past]);
const highlights = past.filter(e => e.featured).slice(0, 6);
---

<Layout
  title="DJ Zippy — Electronic Press Kit"
  description="DJ Zippy EPK: bio, stats, tech rider, press photos and booking contacts."
  noindex={true}
>
  <section class="isolate relative bg-brand-black pt-28 sm:pt-32 pb-12">
    <div class="aurora absolute top-0 left-1/2 -translate-x-1/2 w-[60vw] h-[40vw] rounded-full pointer-events-none"></div>
    <div class="container mx-auto px-6 sm:px-8 lg:px-12 relative z-30">
      <span class="inline-block px-3 py-1 border border-brand-orange/50 rounded-full text-brand-orange text-xs font-bold tracking-widest mb-6">
        ELECTRONIC PRESS KIT — CONFIDENTIAL
      </span>
      <h1 class="font-display text-4xl md:text-6xl font-black leading-tight mb-2">DJ ZIPPY<span class="text-brand-orange">.</span></h1>
      <h2 class="font-display text-xl md:text-2xl font-bold text-brand-orange mb-4">{EPK_BIO.tagline}</h2>
      <p class="text-gray-400 max-w-2xl text-lg">{EPK_BIO.short}</p>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-10 max-w-3xl">
        {[
          { n: `${stats.shows}+`, l: 'Shows played' },
          { n: String(stats.festivalStages), l: 'Festival stages' },
          { n: String(stats.countries), l: 'Countries' },
          { n: `${stats.yearsActive}+`, l: 'Years active' },
        ].map(s => (
          <div class="bg-brand-gray border border-white/5 rounded-xl p-4 text-center">
            <span class="block font-display font-black text-3xl text-brand-orange">{s.n}</span>
            <span class="block text-xs text-gray-400 uppercase tracking-widest mt-1">{s.l}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-brand-black py-12 border-t border-white/5">
    <div class="container mx-auto px-6 sm:px-8 lg:px-12 grid md:grid-cols-2 gap-12">
      <div>
        <h3 class="font-display text-2xl font-bold mb-5">Biography</h3>
        <div class="space-y-4 text-gray-400 leading-relaxed">
          {EPK_BIO.long.map(p => <p>{p}</p>)}
        </div>
        <div class="mt-6 flex flex-wrap gap-2">
          {EPK_BIO.genres.map(g => (
            <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-full text-xs text-gray-300 uppercase tracking-wider">{g}</span>
          ))}
        </div>
        <p class="mt-4 text-sm text-gray-500">Base: {EPK_BIO.base} · {EPK_BIO.affiliations.join(' · ')}</p>
      </div>
      <div>
        <h3 class="font-display text-2xl font-bold mb-5">Featured Performance</h3>
        <div class="aspect-video rounded-xl overflow-hidden border border-white/10">
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${EPK_FEATURED_VIDEO.youtubeId}`}
            title={EPK_FEATURED_VIDEO.title}
            class="w-full h-full"
            loading="lazy"
            allow="encrypted-media; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
        <p class="text-sm text-gray-500 mt-2">{EPK_FEATURED_VIDEO.title}</p>
      </div>
    </div>
  </section>

  <section class="bg-brand-dark py-12 border-t border-white/5">
    <div class="container mx-auto px-6 sm:px-8 lg:px-12">
      <h3 class="font-display text-2xl font-bold mb-6">Career Highlights</h3>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {highlights.map(e => (
          <div class="bg-brand-gray border-l-4 border-brand-orange rounded-r-lg p-4">
            <span class="block font-display font-bold text-white">{e.title}</span>
            <span class="block text-sm text-gray-400">{e.location} · {e.date.slice(0, 4)}{e.subtitle ? ` · ${e.subtitle}` : ''}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-brand-black py-12 border-t border-white/5">
    <div class="container mx-auto px-6 sm:px-8 lg:px-12 grid md:grid-cols-2 gap-12">
      <div>
        <h3 class="font-display text-2xl font-bold mb-6">Press Photos <span class="text-sm font-body font-normal text-gray-500">(click to download)</span></h3>
        <div class="grid grid-cols-2 gap-4">
          {EPK_PHOTOS.map(p => (
            <a href={p.url} download={p.download} data-track="epk_photo_download"
              class="group relative block rounded-xl overflow-hidden border border-white/10 hover:border-brand-orange/60 transition-colors">
              <img src={p.url} alt={p.label} loading="lazy" decoding="async" class="w-full aspect-square object-cover" />
              <span class="absolute bottom-0 inset-x-0 bg-black/70 text-[11px] text-gray-300 px-3 py-2">{p.label}</span>
            </a>
          ))}
        </div>
      </div>
      <div>
        <h3 class="font-display text-2xl font-bold mb-6">Tech Rider</h3>
        <dl class="space-y-3 text-sm">
          {Object.entries(EPK_TECH_RIDER).map(([k, v]) => (
            <div class="flex gap-4 bg-brand-gray/60 rounded-lg p-3 border border-white/5">
              <dt class="w-24 flex-shrink-0 text-[11px] font-bold uppercase tracking-widest text-brand-orange pt-0.5">{k}</dt>
              <dd class="text-gray-300">{v}</dd>
            </div>
          ))}
        </dl>
        <h4 class="font-display text-lg font-bold mt-8 mb-3">Hospitality</h4>
        <ul class="list-disc list-inside text-sm text-gray-400 space-y-1">
          {EPK_HOSPITALITY.map(h => <li>{h}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-brand-dark py-12 border-t border-white/5">
    <div class="container mx-auto px-6 sm:px-8 lg:px-12 text-center">
      <h3 class="font-display text-2xl font-bold mb-2">Booking & Press</h3>
      <p class="text-gray-400 mb-6">Availability, fees and full-resolution assets on request.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`mailto:${EPK_CONTACTS.bookings}?subject=DJ%20Zippy%20%E2%80%94%20Booking%20Inquiry`} data-track="booking"
          class="bg-brand-orange hover:bg-white hover:text-brand-black text-white text-sm font-bold uppercase tracking-widest px-6 py-3 rounded-full transition-colors">
          Book DJ Zippy
        </a>
        <a href={EPK_CONTACTS.ra} target="_blank" rel="noopener noreferrer"
          class="border border-white/20 text-gray-300 hover:border-brand-orange hover:text-brand-orange text-sm font-bold uppercase tracking-widest px-6 py-3 rounded-full transition-colors">
          Resident Advisor
        </a>
      </div>
    </div>
  </section>
</Layout>
