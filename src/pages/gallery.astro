---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="DJ Zippy Gallery | Live Performances & House Music Therapy Moments"
  description="Photo gallery of DJ Zippy's live performances, festival appearances, and House Music Therapy moments across Serbia including Exit Festival and Belgrade venues."
>
  <script slot="head" type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "@id": "https://zippydj.com/gallery#breadcrumb",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://zippydj.com/" },
          { "@type": "ListItem", "position": 2, "name": "Gallery", "item": "https://zippydj.com/gallery" }
        ]
      },
      {
        "@type": "ImageGallery",
        "@id": "https://zippydj.com/gallery#gallery",
        "name": "DJ Zippy Photo Gallery",
        "description": "Live performance photos and House Music Therapy moments from DJ Zippy's events and festival appearances.",
        "about": { "@id": "https://zippydj.com/#person" }
      }
    ]
  }
  </script>

  <section class="isolate relative min-h-[40vh] flex flex-col items-center justify-center bg-brand-black pt-24 sm:pt-28 pb-12 overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60vw] h-[60vw] bg-brand-orange/10 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="container mx-auto px-6 sm:px-8 lg:px-12 text-center z-30">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex justify-center items-center space-x-2 text-sm text-gray-400">
          <li><a href="/" class="hover:text-brand-orange transition-colors">Home</a></li>
          <li><span class="mx-2">/</span></li>
          <li class="text-white">Gallery</li>
        </ol>
      </nav>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-2">DJ Zippy Gallery</h1>
      <h2 class="font-display text-xl md:text-2xl lg:text-3xl font-bold text-brand-orange mb-4">Live Performances & House Music Therapy Moments</h2>
      <p class="text-gray-400 text-lg md:text-xl max-w-2xl mx-auto">Capturing the energy of the dancefloor. From club nights to festival stages.</p>
    </div>
  </section>

  <section id="gallery" class="isolate relative py-16 sm:py-20 bg-brand-dark border-t border-white/5">
    <div class="container mx-auto px-6 sm:px-8 lg:px-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

        <div class="group relative aspect-square bg-brand-gray rounded-lg overflow-hidden">
          <img
            src="/images/dj-zippy-house-music-dj.webp"
            alt="DJ Zippy performing house music at Exit Festival Dance Arena, Novi Sad, 2025"
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <div class="absolute bottom-4 left-4 right-4">
              <p class="text-white font-display font-bold">Exit Festival - Dance Arena</p>
              <p class="text-gray-300 text-sm">Novi Sad, 2025</p>
            </div>
          </div>
        </div>

        <div class="group relative aspect-square bg-brand-gray rounded-lg overflow-hidden flex items-center justify-center border-2 border-dashed border-white/10"
          role="img" aria-label="DJ Zippy performing house music at Exit Festival Students Stage, Novi Sad, 2025">
          <div class="text-center text-gray-500 p-6">
            <i class="fa-solid fa-image text-4xl mb-3"></i>
            <p class="text-sm">DJ Zippy performing house music at Exit Festival Students Stage, Novi Sad, 2025</p>
          </div>
        </div>

        <div class="group relative aspect-square bg-brand-gray rounded-lg overflow-hidden flex items-center justify-center border-2 border-dashed border-white/10"
          role="img" aria-label="DJ Zippy performing house music at Club Kult, Belgrade, 2025">
          <div class="text-center text-gray-500 p-6">
            <i class="fa-solid fa-image text-4xl mb-3"></i>
            <p class="text-sm">DJ Zippy performing house music at Club Kult, Belgrade, 2025</p>
          </div>
        </div>

        <div class="group relative aspect-square bg-brand-gray rounded-lg overflow-hidden flex items-center justify-center border-2 border-dashed border-white/10"
          role="img" aria-label="DJ Zippy performing house music at Exit Festival AS FM Stage, Novi Sad, 2024">
          <div class="text-center text-gray-500 p-6">
            <i class="fa-solid fa-image text-4xl mb-3"></i>
            <p class="text-sm">DJ Zippy performing house music at Exit Festival AS FM Stage, Novi Sad, 2024</p>
          </div>
        </div>

        <div class="group relative aspect-square bg-brand-gray rounded-lg overflow-hidden flex items-center justify-center border-2 border-dashed border-white/10"
          role="img" aria-label="DJ Zippy performing house music at Krivi Put, Smederevo, 2022">
          <div class="text-center text-gray-500 p-6">
            <i class="fa-solid fa-image text-4xl mb-3"></i>
            <p class="text-sm">DJ Zippy performing house music at Krivi Put, Smederevo, 2022</p>
          </div>
        </div>

        <div class="group relative aspect-square bg-brand-gray rounded-lg overflow-hidden flex items-center justify-center border-2 border-dashed border-white/10"
          role="img" aria-label="House Music Therapy session in the studio, Belgrade, 2024">
          <div class="text-center text-gray-500 p-6">
            <i class="fa-solid fa-image text-4xl mb-3"></i>
            <p class="text-sm">House Music Therapy session in the studio, Belgrade, 2024</p>
          </div>
        </div>

      </div>

      <div class="mt-12 text-center">
        <p class="text-gray-400 mb-4">More photos coming soon.</p>
        <a href="/" class="inline-flex items-center gap-2 text-gray-400 hover:text-brand-orange transition-colors">
          <i class="fa-solid fa-arrow-left"></i> Back to Homepage
        </a>
      </div>
    </div>
  </section>
</Layout>
