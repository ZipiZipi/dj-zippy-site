---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import type { Event } from '../../types/database';

const db = (Astro.locals as any).runtime?.env?.DB;
let events: Event[] = [];

if (db) {
  try {
    const result = await db.prepare('SELECT * FROM events ORDER BY date DESC').all<Event>();
    events = result.results ?? [];
  } catch(e) {}
}
---

<AdminLayout title="Events Management" section="events">
  <div class="mb-8 flex items-center justify-between">
    <p class="text-gray-400 text-sm">{events.length} event{events.length !== 1 ? 's' : ''} total</p>
    <button
      onclick="openModal()"
      class="inline-flex items-center gap-2 bg-brand-orange text-white px-6 py-3 rounded-lg font-bold hover:bg-opacity-90 transition-all"
    >
      <i class="fa-solid fa-plus"></i>
      Add Event
    </button>
  </div>

  {events.length === 0 ? (
    <div class="bg-brand-gray border border-white border-opacity-10 rounded-lg p-12 text-center">
      <i class="fa-solid fa-calendar text-6xl text-gray-600 mb-4"></i>
      <p class="text-gray-400 mb-6">No events yet. Add your first event!</p>
      <button onclick="openModal()" class="inline-flex items-center gap-2 bg-brand-orange text-white px-6 py-3 rounded-lg font-bold hover:bg-opacity-90 transition-all">
        <i class="fa-solid fa-plus"></i> Add Event
      </button>
    </div>
  ) : (
    <div class="bg-brand-gray border border-white border-opacity-10 rounded-lg overflow-hidden">
      <table class="w-full">
        <thead class="bg-brand-dark border-b border-white border-opacity-10">
          <tr>
            <th class="px-6 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Title</th>
            <th class="px-6 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Location</th>
            <th class="px-6 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Date</th>
            <th class="px-6 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Status</th>
            <th class="px-6 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white divide-opacity-5" id="events-tbody">
          {events.map((event) => (
            <tr class="hover:bg-brand-dark transition-colors" id={`row-${event.id}`}>
              <td class="px-6 py-4">
                <p class="font-bold text-white">{event.title}</p>
                {event.featured ? <p class="text-xs text-brand-orange flex items-center gap-1"><i class="fa-solid fa-star"></i> Highlight</p> : null}
                {event.subtitle && <p class="text-xs text-gray-500">{event.subtitle}</p>}
                {event.time && <p class="text-xs text-gray-500">{event.time}</p>}
              </td>
              <td class="px-6 py-4 text-gray-300">{event.location}</td>
              <td class="px-6 py-4 text-gray-300">{event.date}</td>
              <td class="px-6 py-4">
                <span class={`inline-block px-3 py-1 rounded-full text-xs font-bold ${event.status === 'upcoming' ? 'bg-green-500/20 text-green-400' : 'bg-gray-500/20 text-gray-400'}`}>
                  {event.status}
                </span>
              </td>
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <button
                    onclick={`editEvent(${JSON.stringify(JSON.stringify(event))})`}
                    class="text-blue-400 hover:text-blue-300 transition-colors text-sm font-bold"
                  >
                    <i class="fa-solid fa-pen-to-square"></i> Edit
                  </button>
                  <button
                    onclick={`deleteEvent(${event.id})`}
                    class="text-red-400 hover:text-red-300 transition-colors text-sm font-bold"
                  >
                    <i class="fa-solid fa-trash"></i> Delete
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  {/* Modal */}
  <div id="modal" class="hidden fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4" onclick="handleBackdrop(event)">
    <div class="bg-brand-dark border border-white border-opacity-10 rounded-lg max-w-2xl w-full max-h-[90vh] overflow-y-auto">
      <div class="sticky top-0 bg-brand-dark border-b border-white border-opacity-10 px-8 py-4 flex items-center justify-between">
        <h2 id="modal-title" class="font-display font-bold text-2xl text-white">Add Event</h2>
        <button onclick="closeModal()" class="text-gray-400 hover:text-white text-3xl leading-none">&times;</button>
      </div>
      <form id="event-form" class="p-8 space-y-5">
        <input type="hidden" id="event-id" value="" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-bold text-white mb-2">Title <span class="text-brand-orange">*</span></label>
            <input type="text" id="f-title" required class="w-full bg-brand-gray border border-white/10 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-brand-orange" placeholder="Event title" />
          </div>
          <div>
            <label class="block text-sm font-bold text-white mb-2">Location <span class="text-brand-orange">*</span></label>
            <input type="text" id="f-location" required class="w-full bg-brand-gray border border-white/10 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-brand-orange" placeholder="Venue, City" />
          </div>
          <div>
            <label class="block text-sm font-bold text-white mb-2">Date <span class="text-brand-orange">*</span></label>
            <input type="date" id="f-date" required class="w-full bg-brand-gray border border-white/10 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-brand-orange" />
          </div>
          <div>
            <label class="block text-sm font-bold text-white mb-2">Time</label>
            <input type="time" id="f-time" class="w-full bg-brand-gray border border-white/10 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-brand-orange" />
          </div>
          <div>
            <label class="block text-sm font-bold text-white mb-2">Status <span class="text-brand-orange">*</span></label>
            <select id="f-status" class="w-full bg-brand-gray border border-white/10 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-brand-orange">
              <option value="upcoming">Upcoming</option>
              <option value="past">Past</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-bold text-white mb-2">Subtitle</label>
            <input type="text" id="f-subtitle" class="w-full bg-brand-gray border border-white/10 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-brand-orange" placeholder="Optional subtitle" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-bold text-white mb-2">Description</label>
          <textarea id="f-description" rows="3" class="w-full bg-brand-gray border border-white/10 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-brand-orange resize-none" placeholder="Optional description..."></textarea>
        </div>
        <div>
          <label class="block text-sm font-bold text-white mb-2">Ticket / Event Link</label>
          <input type="url" id="f-link" class="w-full bg-brand-gray border border-white/10 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-brand-orange" placeholder="https://..." />
        </div>
        <div class="bg-brand-gray border border-white/10 rounded-lg p-4">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="f-featured" class="w-4 h-4 rounded accent-brand-orange" />
            <span class="text-white font-bold"><i class="fa-solid fa-star text-brand-orange mr-1"></i> Highlight</span>
            <span class="text-xs text-gray-500 ml-2">Pin to top of Past Highlights on the site</span>
          </label>
        </div>
        <div id="form-error" class="hidden text-red-400 text-sm py-2"></div>
        <div class="flex gap-3 pt-4 border-t border-white/10">
          <button type="submit" id="submit-btn" class="flex-1 bg-brand-orange text-white px-6 py-3 rounded-lg font-bold hover:bg-opacity-90 transition-all">
            Save Event
          </button>
          <button type="button" onclick="closeModal()" class="flex-1 bg-brand-gray text-white px-6 py-3 rounded-lg font-bold hover:bg-white/10 transition-all">
            Cancel
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    let editingId: number | null = null;

    function openModal(data?: any) {
      editingId = data?.id ?? null;
      const modal = document.getElementById('modal')!;
      const title = document.getElementById('modal-title')!;
      const btn = document.getElementById('submit-btn')!;

      title.textContent = editingId ? 'Edit Event' : 'Add Event';
      btn.textContent = editingId ? 'Update Event' : 'Save Event';

      (document.getElementById('event-id') as HTMLInputElement).value = editingId ? String(editingId) : '';
      (document.getElementById('f-title') as HTMLInputElement).value = data?.title ?? '';
      (document.getElementById('f-location') as HTMLInputElement).value = data?.location ?? '';
      (document.getElementById('f-date') as HTMLInputElement).value = data?.date ?? '';
      (document.getElementById('f-time') as HTMLInputElement).value = data?.time ?? '';
      (document.getElementById('f-status') as HTMLSelectElement).value = data?.status ?? 'upcoming';
      (document.getElementById('f-subtitle') as HTMLInputElement).value = data?.subtitle ?? '';
      (document.getElementById('f-description') as HTMLTextAreaElement).value = data?.description ?? '';
      (document.getElementById('f-link') as HTMLInputElement).value = data?.link ?? '';
      (document.getElementById('f-featured') as HTMLInputElement).checked = !!data?.featured;

      hideError();
      modal.classList.remove('hidden');
    }

    function closeModal() {
      document.getElementById('modal')!.classList.add('hidden');
      editingId = null;
    }

    function handleBackdrop(e: MouseEvent) {
      if (e.target === document.getElementById('modal')) closeModal();
    }

    function editEvent(jsonStr: string) {
      openModal(JSON.parse(jsonStr));
    }

    async function deleteEvent(id: number) {
      if (!confirm('Delete this event?')) return;
      try {
        const res = await fetch('/api/admin/events?id=' + id, { method: 'DELETE' });
        const data = await res.json() as { success: boolean; error?: string };
        if (data.success) {
          document.getElementById('row-' + id)?.remove();
        } else {
          alert('Error: ' + (data.error ?? 'Failed to delete'));
        }
      } catch(e) {
        alert('Network error');
      }
    }

    function showError(msg: string) {
      const el = document.getElementById('form-error')!;
      el.textContent = msg;
      el.classList.remove('hidden');
    }
    function hideError() {
      document.getElementById('form-error')!.classList.add('hidden');
    }

    document.getElementById('event-form')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideError();

      const btn = document.getElementById('submit-btn') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Saving...';

      const body = {
        title:       (document.getElementById('f-title') as HTMLInputElement).value.trim(),
        location:    (document.getElementById('f-location') as HTMLInputElement).value.trim(),
        date:        (document.getElementById('f-date') as HTMLInputElement).value,
        time:        (document.getElementById('f-time') as HTMLInputElement).value || null,
        status:      (document.getElementById('f-status') as HTMLSelectElement).value,
        subtitle:    (document.getElementById('f-subtitle') as HTMLInputElement).value.trim() || null,
        description: (document.getElementById('f-description') as HTMLTextAreaElement).value.trim() || null,
        link:        (document.getElementById('f-link') as HTMLInputElement).value.trim() || null,
        featured:    (document.getElementById('f-featured') as HTMLInputElement).checked,
      };

      try {
        const url = editingId ? '/api/admin/events?id=' + editingId : '/api/admin/events';
        const method = editingId ? 'PUT' : 'POST';
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await res.json() as { success: boolean; error?: string };
        if (data.success) {
          closeModal();
          window.location.reload();
        } else {
          showError(data.error ?? 'Failed to save');
        }
      } catch(e) {
        showError('Network error');
      } finally {
        btn.disabled = false;
        btn.textContent = editingId ? 'Update Event' : 'Save Event';
      }
    });
  </script>
</AdminLayout>
