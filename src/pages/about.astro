---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About DJ Zippy | House Music Therapy Creator from Belgrade"
  description="Learn about DJ Zippy (Veljko Nedeljkovic), the House Music Therapy creator from Belgrade, Serbia. A selector dedicated to the groove, the vibe, and the journey."
  activePage="about"
>
  <script slot="head" type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "BreadcrumbList",
        "@id": "https://zippydj.com/about#breadcrumb",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://zippydj.com/" },
          { "@type": "ListItem", "position": 2, "name": "About", "item": "https://zippydj.com/about" }
        ]
      },
      {
        "@type": "AboutPage",
        "@id": "https://zippydj.com/about#page",
        "url": "https://zippydj.com/about",
        "name": "About DJ Zippy",
        "description": "Learn about DJ Zippy (Veljko Nedeljkovic), the House Music Therapy creator from Belgrade, Serbia.",
        "mainEntity": { "@id": "https://zippydj.com/#person" },
        "isPartOf": { "@id": "https://zippydj.com/#website" }
      },
      {
        "@type": "Person",
        "@id": "https://zippydj.com/#person",
        "name": "Zippy",
        "givenName": "Veljko",
        "familyName": "Nedeljkovic",
        "alternateName": ["DJ Zippy", "Zippy DJ", "Zovumezippy", "Zipi"],
        "url": "https://zippydj.com",
        "image": "https://zippydj.com/images/dj-zippy-house-music-dj.webp",
        "description": "Zippy (Veljko Nedeljkovic) is a House and Tech-House selector based in Belgrade, Serbia, known for the 'House Music Therapy' mix series.",
        "jobTitle": "DJ & Producer",
        "homeLocation": { "@type": "City", "name": "Belgrade" },
        "sameAs": [
          "https://musicbrainz.org/artist/a6a53c2e-8fa0-4612-8e43-8de7af43dc2a",
          "https://www.wikidata.org/wiki/Q138220521",
          "https://www.instagram.com/zovumezippy",
          "https://www.youtube.com/@zovumezippy",
          "https://ra.co/dj/zippy-2",
          "https://soundcloud.com/zovumezippy",
          "https://www.mixcloud.com/zovumezippy/",
          "https://www.facebook.com/zovumezippy",
          "https://open.spotify.com/user/31aj2g4yokqhpoxwkpo5odxegsle"
        ]
      }
    ]
  }
  </script>
  {/* Hero / Bio Section */}
  <section class="isolate relative min-h-screen flex flex-col justify-center bg-brand-black pt-24 sm:pt-28 pb-16 overflow-hidden">
    <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 z-30">

      {/* Breadcrumb */}
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-gray-400">
          <li><a href="/" class="hover:text-brand-orange transition-colors">Home</a></li>
          <li><span class="mx-2">/</span></li>
          <li class="text-white">About</li>
        </ol>
      </nav>

      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-4">
        About <span class="text-brand-orange">DJ Zippy</span>
      </h1>
      <p class="text-gray-400 text-lg md:text-xl mb-16">
        DJ Zippy curates frequencies from club nights to festival main stages, dedicated to the groove, the vibe, and the journey.
      </p>

      {/* Bio Grid */}
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        {/* Photo */}
        <div class="flex items-center justify-center">
          <img
            src="/images/dj-zippy-house-music-dj.webp"
            alt="DJ Zippy a DJ from Serbia, creator of House Music Therapy."
            class="w-full max-h-md rounded-lg"
          />
        </div>

        {/* Bio Text */}
        <div>
          <div class="inline-block px-3 py-1 border border-brand-orange/50 rounded-full text-brand-orange text-xs font-bold tracking-widest mb-6">
            THE ARTIST
          </div>
          <h2 class="font-display text-4xl md:text-5xl font-bold mb-8">
            Not a Producer.<br />A <span class="text-brand-orange">Selector.</span>
          </h2>

          <div class="space-y-6 text-gray-400 font-light leading-relaxed">
            <p>
              DJ Zippy's brand, <span class="text-white font-semibold">House Music Therapy</span>, is
              built on the belief that the right groove can heal. While his foundation is strictly{' '}
              <span class="text-white font-semibold">House</span>, Zippy adapts to the energy of the
              night, shifting into <span class="text-white font-semibold">Techno</span> when the
              atmosphere demands darker, driving rhythms.
            </p>
            <p>
              In an era dominated by production credits, the art of selection is the true therapy. DJ
              Zippy specializes in <strong>reading the room</strong>, bridging the gap between the DJ
              booth and the dancefloor.
            </p>
            <p>
              <strong>Reliability is key.</strong> Through his collaboration with{' '}
              <strong class="text-white">Go2 Travel</strong>, DJ Zippy has proven his adaptability,
              making him a safe and exciting bet for any promoter.
            </p>

            {/* Affiliation Cards */}
            <div class="pt-6">
              <h3 class="text-white font-display text-xl mb-4">Proud Member of:</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="p-6 glass-panel rounded-lg border-l-4 border-brand-orange">
                  <h4 class="text-xl font-bold text-white mb-2">KULT TALENTS</h4>
                  <p class="text-sm">
                    Platform for those who dare to experiment, learn, and evolve — the artists who
                    will soon define tomorrow's sound.
                  </p>
                </div>
                <div class="p-6 glass-panel rounded-lg border-l-4 border-brand-orange">
                  <h4 class="text-xl font-bold text-white mb-2">IZUVANJE</h4>
                  <p class="text-sm">
                    Non-EDM party concept blending all kinds of genres and generations operating since
                    2022.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Partners / Affiliations Bar */}
      <div class="mt-12 md:mt-20 flex justify-center items-center gap-6 sm:gap-8 md:gap-16 opacity-50 grayscale hover:grayscale-0 transition-all duration-500 flex-wrap z-30 px-4">
        <div class="flex items-center gap-2" title="Kult Talents Member">
          <i class="fa-solid fa-star text-xl"></i>
          <span class="font-display font-bold text-lg sm:text-xl">KULT TALENTS</span>
        </div>
        <div class="flex items-center gap-2" title="Trusted by Go2 Travel">
          <i class="fa-solid fa-plane text-xl"></i>
          <span class="font-display font-bold text-lg sm:text-xl">GO2 TRAVEL</span>
        </div>
        <div class="flex items-center gap-2" title="Resident Advisor">
          <span class="font-display font-bold text-lg sm:text-xl bg-white text-black px-1">RA</span>
          <span class="font-display font-bold text-lg sm:text-xl">RESIDENT ADVISOR</span>
        </div>
      </div>
    </div>
  </section>

</Layout>
