  </script>

  <style is:global>
    .coverflow {
      perspective: 600px;
      perspective-origin: 50% 50%;
      position: relative;
      height: 340px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .coverflow-item {
      position: absolute;
      top: 50%;
      width: clamp(150px, 22vw, 280px);
      transition: transform 0.7s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.5s ease;
      transform-style: preserve-3d;
      cursor: pointer;
      user-select: none;
    }
    .coverflow-item.active { cursor: default; }
    .cf-disc {
      width: clamp(125px, 18vw, 230px);
      height: clamp(125px, 18vw, 230px);
      background:
        radial-gradient(circle at center, transparent 18%, #0d0d0d 19%),
        repeating-radial-gradient(circle at center, rgba(30,30,30,1) 0px, rgba(20,20,20,1) 1px, rgba(15,15,15,1) 2px, rgba(25,25,25,1) 3px),
        linear-gradient(135deg, #111 0%, #0a0a0a 50%, #111 100%);
      border-radius: 50%;
      position: relative;
      margin: 0 auto;
      box-shadow: 0 4px 30px rgba(0,0,0,0.7), 0 0 0 2px rgba(255,255,255,0.08), 0 0 0 4px rgba(0,0,0,0.5), inset 0 0 60px rgba(0,0,0,0.8);
    }
    .cf-disc::before {
      content: '';
      position: absolute;
      inset: 2%;
      border-radius: 50%;
      background:
        repeating-radial-gradient(circle at center, transparent, transparent 1.5px, rgba(255,255,255,0.03) 2px, transparent 2.5px),
        repeating-radial-gradient(circle at center, transparent, transparent 5px, rgba(255,255,255,0.015) 5.5px, transparent 6px),
        linear-gradient(135deg, transparent 20%, rgba(255,255,255,0.07) 45%, transparent 55%, rgba(255,255,255,0.04) 80%, transparent 100%);
      pointer-events: none;
    }
    .cf-disc::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.08);
      box-shadow: inset 0 0 8px rgba(255,255,255,0.03);
      pointer-events: none;
    }
    .cf-label {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 38%; height: 38%;
      border-radius: 50%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0;
      box-shadow: 0 0 0 3px rgba(0,0,0,0.5), 0 0 15px rgba(0,0,0,0.3);
      z-index: 1;
      background-size: cover;
      background-position: center;
      overflow: hidden;
    }
    .cf-label::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: -1;
    }
    .cf-play-overlay {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      font-size: 3rem;
      color: rgba(255,255,255,0.9);
      text-shadow: 0 4px 15px rgba(0,0,0,0.8);
      opacity: 0;
      transition: opacity 0.3s;
      pointer-events: none;
      z-index: 10;
    }
    .coverflow-item.active:hover .cf-play-overlay { opacity: 1; }
    .cf-label-title {
      font-size: clamp(0.5rem, 1vw, 0.7rem);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.95);
      text-shadow: 0 1px 3px rgba(0,0,0,0.5);
      line-height: 1;
      margin-bottom: 10px;
    }
    .cf-label-sub {
      font-size: clamp(0.4rem, 0.8vw, 0.55rem);
      font-weight: 600;
      color: rgba(255,255,255,0.7);
      text-shadow: 0 1px 2px rgba(0,0,0,0.4);
      line-height: 1;
      margin-top: 10px;
    }
    .cf-spindle {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 8%; height: 8%;
      min-width: 8px; min-height: 8px;
      background: radial-gradient(circle, #1a1a1a 40%, #0a0a0a 100%);
      border-radius: 50%;
      box-shadow: inset 0 0 4px rgba(255,255,255,0.2), 0 0 2px rgba(0,0,0,0.8);
      z-index: 2;
    }
    .coverflow-item.active .cf-disc {
      box-shadow: 0 8px 40px rgba(0,0,0,0.8), 0 0 0 3px rgba(255,255,255,0.06), inset 0 0 60px rgba(0,0,0,0.8), 0 0 46px rgba(255,85,0,0.12);
    }
    .coverflow-nav {
      position: absolute;
      top: 40%;
      transform: translateY(-50%);
      z-index: 20;
      width: 44px; height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.3);
      transition: color 0.3s;
      cursor: pointer;
      background: none;
      border: none;
    }
    .coverflow-nav:hover { color: #FF5500; }
    .coverflow-nav.prev { left: 0; }
    .coverflow-nav.next { right: 0; }
    .coverflow-fade-wrap {
      position: relative;
      /* extra vertical room so the active disc's glow/shadow isn't clipped by the
         horizontal fade mask (a mask clips to its own box on all sides) */
      padding-top: 44px;
      padding-bottom: 44px;
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 7%, black 93%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, black 7%, black 93%, transparent 100%);
    }
    /* On narrow screens only 1–2 discs show — drop the side fade so the active
       disc is never clipped, and keep the coverflow compact. */
    @media (max-width: 640px) {
      .coverflow { height: clamp(260px, 64vw, 300px); }
      .coverflow-fade-wrap { -webkit-mask-image: none; mask-image: none; padding-top: 16px; padding-bottom: 16px; }
    }

  </style>

  <!-- "One Record, Every Horizon" — the fixed world every section scrolls through -->
  <Journey />

  <!-- Chapter 0 — the brand, under the stars -->
  <section id="ch-brand" class="j-chapter min-h-[100svh] flex items-center justify-center" data-scene="ecl">
    <div class="j-brand-block text-center px-6">
      <p class="j-brand-kicker">ONE RECORD. EVERY HORIZON.</p>
      <h1 class="j-brand-h glitch-text glitch-auto">ZIPPY<span class="text-brand-orange">.</span></h1>
      <p class="j-brand-sub">HOUSE MUSIC THERAPY</p>
      <div class="eq-bars mt-4" aria-hidden="true">
        {Array.from({ length: 24 }).map(() => <span></span>)}
      </div>
    </div>
    <div class="j-hint absolute bottom-[5%] left-1/2 -translate-x-1/2" aria-hidden="true">SCROLL</div>
  </section>

  <!-- Chapter 1 — FESTIVAL (canyon): dig through the crate -->
  <section id="ch-collection" class="j-chapter min-h-[100svh] py-24 flex flex-col justify-center" data-scene="can">
      <div id="highlights" class="relative pb-6 z-30">
        <div class="container mx-auto px-6 sm:px-8 lg:px-12">
          <div class="j-chapter-head">
            <span class="j-kicker">VENUE 01 — OPEN AIR · FESTIVAL</span>
            <h2 class="j-title">THE COLLECTION</h2>
            <p class="j-sub">Open sky, fifty thousand hearts. Dig through the crate and pull a record.</p>
          </div>
          <div class="relative px-6 sm:px-14">
            <button class="coverflow-nav prev" aria-label="Previous"><i class="fa-solid fa-chevron-left text-xl"></i></button>
            <div class="coverflow-fade-wrap">
              <div class="coverflow" id="coverflow-container">
                <div class="crate-sleeve" aria-hidden="true"><div class="crate-sleeve-inner"></div></div>
                {featuredMixes.map(m => (
                  <article class="coverflow-item text-center" data-link={m.link} data-platform={m.platform} data-title={m.title}>
                    <div class="cf-disc">
                      <div class={m.thumbnail ? 'cf-label' : 'cf-label cf-label-art'} style={m.thumbnail ? `background-image: url('${ytThumb(m.thumbnail, 'mqdefault')}');` : undefined}>
                        {!m.thumbnail && <span class="cf-label-title">ZIPPY</span>}
                        {!m.thumbnail && <span class="cf-label-sub">{m.platform.toUpperCase()}</span>}
                      </div>
                      <div class="cf-spindle"></div>
                      <i class="fa-solid fa-play cf-play-overlay"></i>
                    </div>
                    <div class="mt-3 text-xs text-gray-400 space-y-0.5">
                      <span class="block font-semibold text-white/80">{m.title}</span>
                      <span class="block text-gray-500">{m.platform.charAt(0).toUpperCase() + m.platform.slice(1)}</span>
                    </div>
                  </article>
                ))}
              </div>
            </div>
            <button class="coverflow-nav next" aria-label="Next"><i class="fa-solid fa-chevron-right text-xl"></i></button>
          </div>
          <div class="mt-16 sm:mt-20 text-center">
            <a href="/mixes" class="inline-flex items-center gap-2 text-gray-400 hover:text-brand-orange transition-colors">
              <i class="fa-solid fa-headphones"></i> Listen Now
            </a>
          </div>
        </div>
      </div>
  </section>

  <!-- Chapter 2 — CLUB (night forest): the upcoming sessions -->
  <section id="ch-events" class="j-chapter min-h-[100svh] py-24 flex flex-col justify-center" data-scene="for">
    <div class="container mx-auto px-6 sm:px-8 lg:px-12 relative z-10">
      <div class="j-chapter-head">
        <span class="j-kicker">VENUE 02 — UNDERGROUND · CLUB</span>
        <h2 class="j-title">UPCOMING THERAPY</h2>
        <p class="j-sub">Four walls, hypnosis at 124 BPM. Catch the next session.</p>
      </div>
      <div class="mb-8">
        <Countdown event={upcoming[0] ?? null} />
      </div>
      <div class="space-y-1 flex flex-col items-center max-w-3xl mx-auto" data-reveal>
        {homeUpcoming.length === 0 && <p class="text-gray-400 text-center">No upcoming events scheduled.</p>}
        {homeUpcoming.map(e => {
          const displayDate = e.date.split('-').reverse().join('/') + (e.time ? ` | ${e.time}` : '');
          return (
            <div class="w-full">
              <div class="flex flex-col md:flex-row items-center bg-brand-gray p-2 rounded-lg border-l-4 border-brand-orange hover:bg-white/5 transition-colors">
                <div class="md:w-2/5 text-center md:text-left mb-1 md:mb-0 flex-shrink-0">
                  <span class="block text-sm sm:text-base md:text-lg lg:text-xl font-display font-bold">{e.title.toUpperCase()}</span>
                  <span class="text-xs md:text-sm text-gray-500 uppercase tracking-widest">{e.location}</span>
                </div>
                <div class="md:flex-1 text-center md:text-left mb-1 md:mb-0 px-2 min-w-0">
                  <span class="block text-sm md:text-base lg:text-lg font-bold text-white">{e.subtitle || e.title}</span>
                  <span class="text-gray-400 text-xs md:text-sm">{displayDate}</span>
                </div>
                {e.link
                  ? <a href={e.link} target="_blank" rel="noopener noreferrer" data-track="tickets"
                      class="flex-shrink-0 bg-brand-orange hover:bg-white hover:text-brand-black text-white text-[11px] font-bold uppercase tracking-widest px-3.5 py-1.5 rounded-full transition-colors mb-1 md:mb-0 md:mr-2">
                      Get Tickets
                    </a>
                  : <a href="/#contact" data-track="booking"
                      class="flex-shrink-0 border border-white/20 text-gray-300 hover:border-brand-orange hover:text-brand-orange text-[11px] font-bold uppercase tracking-widest px-3.5 py-1.5 rounded-full transition-colors mb-1 md:mb-0 md:mr-2">
                      Book a Date
                    </a>}
              </div>
            </div>
          );
        })}
      </div>
      <div class="mt-8 text-center">
        <a href="/events" class="inline-flex items-center gap-2 text-gray-400 hover:text-brand-orange transition-colors">
          <i class="fa-solid fa-calendar"></i> View All Events & Past Highlights
        </a>
      </div>
    </div>
  </section>

  <!-- Chapter 3 — GOLDEN HOUR (open sea): a breath between sets -->
  <section id="ch-sea" class="j-chapter min-h-[80svh] flex items-center justify-center" data-scene="sea">
    <div class="j-chapter-head px-6">
      <span class="j-kicker">VENUE 03 — ROOFTOPS &amp; SHORES · SUNSET SESSION</span>
      <h2 class="j-title">GOLDEN HOUR</h2>
      <p class="j-sub max-w-xl mx-auto">Salt air, slow grooves. Not a producer — a selector, reading every room from festival to bar.</p>
    </div>
  </section>

  <!-- Chapter 4 — AFTERHOURS (underwater): the deep end holds the unreleased -->
  <section id="ch-lead" class="j-chapter min-h-[90svh] py-24 flex items-center" data-scene="und">
    <div class="container mx-auto px-6">
      <div class="j-chapter-head">
        <span class="j-kicker">VENUE 04 — 5AM · AFTERHOURS</span>
        <h2 class="j-title">THE DEEP END</h2>
        <p class="j-sub">Weightless. Down here live the unreleased mixes.</p>
      </div>
      <LeadMagnet variant="story" />
    </div>
  </section>

  <!-- Chapter 5 — SUNRISE (summit): the record finds its turntable -->
  <section id="ch-summit" class="j-chapter min-h-[100svh] flex items-end justify-center pb-[14svh]" data-scene="sum">
    <div class="text-center px-6">
      <div class="j-chapter-head mb-7">
        <span class="j-kicker">EVERY NIGHT ENDS THE SAME WAY</span>
        <h2 class="j-title">SUNRISE</h2>
        <p class="j-sub">Wherever your floor is — bring the therapy.</p>
      </div>
      <a href="#contact" data-track="booking"
        class="inline-block bg-brand-orange hover:bg-white hover:text-brand-black text-white text-sm font-bold uppercase tracking-widest px-8 py-4 rounded-full transition-colors">
        Book DJ Zippy
      </a>
    </div>
  </section>

  <div class="marquee relative z-10 bg-brand-black border-y border-white/5 py-4 sm:py-5" aria-hidden="true">
    <div class="marquee__track">
      {[0, 1].map(() => ticker.map((w) => (
        <span class="inline-flex items-center gap-10">
          <span class="font-display text-lg sm:text-2xl font-black uppercase tracking-widest text-white/15">{w}</span>
          <span class="text-brand-orange text-base">&#9679;</span>
        </span>
      )))}
    </div>
  </div>

  <LeadMagnet variant="popup" />

  <script is:inline>
  function initCoverflow() {
    // === COVERFLOW === (items are server-rendered from the DB)
    var coverflowContainer = document.getElementById('coverflow-container');
    if (coverflowContainer && !coverflowContainer.dataset.cfReady) {
      coverflowContainer.dataset.cfReady = '1';
      var items = document.querySelectorAll('.coverflow-item');
      if (items.length) {
        var active = 0;
        function getGap() {
          var vw = window.innerWidth;
          if (vw < 640) return vw * 0.28;
          if (vw < 1024) return vw * 0.2;
          return Math.min(vw * 0.16, 220);
        }
        function update() {
          var gap = getGap();
          var half = Math.floor(items.length / 2);
          items.forEach(function(el, i) {
            var off = i - active;
            if (off > half) off -= items.length;
            if (off < -half) off += items.length;
            var abs = Math.abs(off);
            var tx = off * gap;
            var tz = abs === 0 ? 80 : -(abs * 140);
            // Crate effect: side records sit lower (tucked in the bin), the
            // active one stands pulled out above them.
            var tyP = abs === 0 ? -56 : -44;
            var ry = off < 0 ? 55 : off > 0 ? -55 : 0;
            var sc = abs === 0 ? 1.1 : Math.max(0.65, 0.85 - (abs - 1) * 0.15);
            var op = abs > 2 ? 0.15 : abs === 0 ? 1 : 0.5 - (abs - 1) * 0.15;
            var prevOff = parseInt(el.getAttribute('data-off') || String(i), 10);
            var delta = Math.abs(off - prevOff);
            var wrapping = delta > half;
            el.setAttribute('data-off', String(off));
            if (wrapping) {
              // Teleport instantly with no transition and invisible
              el.style.transition = 'none';
              el.style.opacity = '0';
              el.style.transform = 'translateY(' + tyP + '%) translateX(' + tx + 'px) translateZ(' + tz + 'px) rotateY(' + ry + 'deg) scale(' + sc + ')';
              el.style.zIndex = String(10 - abs);
              // Re-enable transition after paint so it fades in at new position
              requestAnimationFrame(function() {
                requestAnimationFrame(function() {
                  el.style.transition = '';
                  el.style.opacity = String(op);
                });
              });
            } else {
              el.style.transition = '';
              el.style.transform = 'translateY(' + tyP + '%) translateX(' + tx + 'px) translateZ(' + tz + 'px) rotateY(' + ry + 'deg) scale(' + sc + ')';
              el.style.zIndex = String(10 - abs);
              el.style.opacity = String(op);
            }
            if (off === 0) el.classList.add('active');
            else el.classList.remove('active');
          });
        }
        // Record-change FX: shockwave ring from the spindle, ambient hue shift
        // of the psy layer, and a pop on the newly active disc.
        function fireChangeFx() {
          var cf = document.querySelector('.coverflow');
          if (!cf || window.__motionOff()) return;
          var w = document.createElement('div');
          w.className = 'cf-shockwave';
          cf.appendChild(w);
          setTimeout(function() { w.remove(); }, 750);
          document.documentElement.style.setProperty('--psy-shift', (active * 16) + 'deg');
          // Step along the crate row: pan the store photo with each record
          document.documentElement.style.setProperty('--shelf-x', (((active % items.length) - items.length / 2) * 3) + '%');
          var d = items[active].querySelector('.cf-disc');
          if (d) { d.classList.remove('disc-pop'); void d.offsetWidth; d.classList.add('disc-pop'); }
          // Cardboard sleeve rises out of the crate; the disc slides out of it
          var sl = cf.querySelector('.crate-sleeve');
          if (sl) { sl.classList.remove('pull'); void sl.offsetWidth; sl.classList.add('pull'); }
        }
        items.forEach(function(el, i) {
          el.addEventListener('click', function() {
            if (active === i) {
              var link = el.getAttribute('data-link');
              if (!link) return;
              var played = window.ZippyDock && window.ZippyDock.play({
                platform: el.getAttribute('data-platform'),
                link: link,
                title: el.getAttribute('data-title'),
              });
              if (!played) window.open(link, '_blank', 'noopener,noreferrer');
            } else { active = i; update(); fireChangeFx(); }
          });
        });
        function wrap(i) { return ((i % items.length) + items.length) % items.length; }
        // Hook for the scrollytelling act: scroll position drives record flips.
        window.__cfCount = items.length;
        window.__cfGoto = function(i) {
          var n = wrap(i);
          if (n === active) return;
          active = n; update(); fireChangeFx();
        };
        var prevBtn = document.querySelector('.coverflow-nav.prev');
        var nextBtn = document.querySelector('.coverflow-nav.next');
        if (prevBtn) prevBtn.addEventListener('click', function() { active = wrap(active - 1); update(); fireChangeFx(); });
        if (nextBtn) nextBtn.addEventListener('click', function() { active = wrap(active + 1); update(); fireChangeFx(); });
        var startX = 0;
        var cfEl = document.querySelector('.coverflow');
        if (cfEl) {
          cfEl.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
          cfEl.addEventListener('touchend', function(e) {
            var diff = startX - e.changedTouches[0].clientX;
            if (Math.abs(diff) > 50) { active = wrap(diff > 0 ? active + 1 : active - 1); update(); fireChangeFx(); }
          }, { passive: true });
        }
        window.addEventListener('resize', update);
        update();
      }
    }
  }
  document.addEventListener('astro:page-load', initCoverflow);

  </script>

</Layout>
