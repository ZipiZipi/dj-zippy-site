---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import Countdown from '../components/Countdown.astro';
import LeadMagnet from '../components/LeadMagnet.astro';
import { getEvents, getMixes, dateParts, ytThumb } from '../lib/content';

const db = (Astro.locals as any).runtime?.env?.DB;
const { upcoming } = await getEvents(db);
const homeUpcoming = upcoming.slice(0, 4);
const { featured: featuredMixes } = await getMixes(db);

// Higgsfield promo teaser (set via POST /api/admin/teaser). When present it
// plays as a lazy hero video layer and powers the "Download Promo Video" CTA.
let heroVideo = '';
if (db) {
  try {
    const row = await db.prepare("SELECT value FROM site_settings WHERE key='hero_video_url'").first();
    heroVideo = (row?.value as string) ?? '';
  } catch { /* table may not exist yet — hero gradient is the fallback */ }
}

const ticker = ['House Music Therapy', 'Exit Festival', 'Belgrade', 'Deep House', 'Tech House', 'Novi Sad', 'Selector', 'Grooves'];
---

<Layout
  title="Zippy | House Music Therapy | DJ from Serbia"
  description="Official website of Zippy (DJ Zippy). House Music Therapy creator from Belgrade, Serbia. Curator, selector, and vibe architect. Book now."
>
  <script slot="head" type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "ProfilePage",
        "@id": "https://zippydj.com/#profilepage",
        "mainEntity": { "@id": "https://zippydj.com/#person" },
        "dateCreated": "2024-01-01T00:00:00-05:00",
        "dateModified": "2025-07-13T00:00:00-05:00"
      },
      {
        "@type": ["Person","MusicGroup"],
        "@id": "https://zippydj.com/#person",
        "name": "DJ Zippy",
        "givenName": "Veljko",
        "familyName": "Nedeljkovic",
        "alternateName": ["Zippy","Zippy DJ","Zovumezippy","Zipi","Veljko Nedeljković"],
        "url": "https://zippydj.com",
        "image": {
          "@type": "ImageObject",
          "url": "https://zippydj.com/images/dj-zippy-house-music-dj.webp",
          "width": 1200,
          "height": 1200,
          "caption": "DJ Zippy — House Music Therapy"
        },
        "description": "DJ Zippy (Veljko Nedeljković) is a House and Tech-House DJ and selector based in Belgrade, Serbia, known for the 'House Music Therapy' mix series and performances at Exit Festival and major regional clubs.",
        "jobTitle": "DJ & Selector",
        "hasOccupation": { "@type": "Occupation", "name": "Disc Jockey", "occupationalCategory": "27-2099.00" },
        "nationality": { "@type": "Country", "name": "Serbia" },
        "birthPlace": { "@type": "City", "name": "Belgrade" },
        "homeLocation": { "@type": "City", "name": "Belgrade" },
        "address": { "@type": "PostalAddress", "addressLocality": "Belgrade", "addressCountry": "RS" },
        "genre": ["House","Tech House","Deep House","Techno","Organic House"],
        "knowsLanguage": ["sr","en"],
        "memberOf": [
          { "@type": "Organization", "name": "Kult Talents" },
          { "@type": "Organization", "name": "Izuvanje" }
        ],
        "sameAs": [
          "https://musicbrainz.org/artist/a6a53c2e-8fa0-4612-8e43-8de7af43dc2a",
          "https://www.wikidata.org/wiki/Q138220521",
          "https://www.instagram.com/zovumezippy",
          "https://www.youtube.com/@zovumezippy",
          "https://ra.co/dj/zippy-2",
          "https://soundcloud.com/zovumezippy",
          "https://www.mixcloud.com/zovumezippy/",
          "https://www.tiktok.com/@zovumezippy",
          "https://www.facebook.com/zovumezippy",
          "https://open.spotify.com/user/31aj2g4yokqhpoxwkpo5odxegsle",
          "https://www.deezer.com/en/profile/2582254702"
        ],
        "knowsAbout": ["House Music","Tech House","Deep House","Techno","DJing","Music Selection"]
      },
      {
        "@type": "Organization",
        "@id": "https://zippydj.com/#organization",
        "name": "DJ Zippy",
        "alternateName": "House Music Therapy",
        "url": "https://zippydj.com",
        "logo": {
          "@type": "ImageObject",
          "url": "https://zippydj.com/images/dj-zippy-house-music-dj.webp",
          "width": 1200,
          "height": 1200
        },
        "image": "https://zippydj.com/images/dj-zippy-house-music-dj.webp",
        "founder": { "@id": "https://zippydj.com/#person" },
        "description": "House Music Therapy - DJ brand curating frequencies, grooves, and the journey through house music.",
        "address": { "@type": "PostalAddress", "addressLocality": "Belgrade", "addressCountry": "RS" },
        "contactPoint": {
          "@type": "ContactPoint",
          "email": "veljkoned@gmail.com",
          "contactType": "booking",
          "areaServed": ["RS","EU"],
          "availableLanguage": ["en","sr"]
        },
        "sameAs": [
          "https://www.instagram.com/zovumezippy",
          "https://www.youtube.com/@zovumezippy",
          "https://ra.co/dj/zippy-2"
        ]
      },
      {
        "@type": "WebSite",
        "@id": "https://zippydj.com/#website",
        "name": "DJ Zippy",
        "url": "https://zippydj.com",
        "publisher": { "@id": "https://zippydj.com/#organization" }
      }
    ]
  }
  </script>

  <style is:global>
    .coverflow {
      perspective: 600px;
      perspective-origin: 50% 50%;
      position: relative;
      height: 340px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .coverflow-item {
      position: absolute;
      top: 50%;
      width: clamp(150px, 22vw, 280px);
      transition: transform 0.7s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.5s ease;
      transform-style: preserve-3d;
      cursor: pointer;
      user-select: none;
    }
    .coverflow-item.active { cursor: default; }
    .cf-disc {
      width: clamp(125px, 18vw, 230px);
      height: clamp(125px, 18vw, 230px);
      background:
        radial-gradient(circle at center, transparent 18%, #0d0d0d 19%),
        repeating-radial-gradient(circle at center, rgba(30,30,30,1) 0px, rgba(20,20,20,1) 1px, rgba(15,15,15,1) 2px, rgba(25,25,25,1) 3px),
        linear-gradient(135deg, #111 0%, #0a0a0a 50%, #111 100%);
      border-radius: 50%;
      position: relative;
      margin: 0 auto;
      box-shadow: 0 4px 30px rgba(0,0,0,0.7), 0 0 0 2px rgba(255,255,255,0.08), 0 0 0 4px rgba(0,0,0,0.5), inset 0 0 60px rgba(0,0,0,0.8);
    }
    .cf-disc::before {
      content: '';
      position: absolute;
      inset: 2%;
      border-radius: 50%;
      background:
        repeating-radial-gradient(circle at center, transparent, transparent 1.5px, rgba(255,255,255,0.03) 2px, transparent 2.5px),
        repeating-radial-gradient(circle at center, transparent, transparent 5px, rgba(255,255,255,0.015) 5.5px, transparent 6px),
        linear-gradient(135deg, transparent 20%, rgba(255,255,255,0.07) 45%, transparent 55%, rgba(255,255,255,0.04) 80%, transparent 100%);
      pointer-events: none;
    }
    .cf-disc::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.08);
      box-shadow: inset 0 0 8px rgba(255,255,255,0.03);
      pointer-events: none;
    }
    .cf-label {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 38%; height: 38%;
      border-radius: 50%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0;
      box-shadow: 0 0 0 3px rgba(0,0,0,0.5), 0 0 15px rgba(0,0,0,0.3);
      z-index: 1;
      background-size: cover;
      background-position: center;
      overflow: hidden;
    }
    .cf-label::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: -1;
    }
    .cf-play-overlay {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      font-size: 3rem;
      color: rgba(255,255,255,0.9);
      text-shadow: 0 4px 15px rgba(0,0,0,0.8);
      opacity: 0;
      transition: opacity 0.3s;
      pointer-events: none;
      z-index: 10;
    }
    .coverflow-item.active:hover .cf-play-overlay { opacity: 1; }
    .cf-label-title {
      font-size: clamp(0.5rem, 1vw, 0.7rem);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.95);
      text-shadow: 0 1px 3px rgba(0,0,0,0.5);
      line-height: 1;
      margin-bottom: 10px;
    }
    .cf-label-sub {
      font-size: clamp(0.4rem, 0.8vw, 0.55rem);
      font-weight: 600;
      color: rgba(255,255,255,0.7);
      text-shadow: 0 1px 2px rgba(0,0,0,0.4);
      line-height: 1;
      margin-top: 10px;
    }
    .cf-spindle {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 8%; height: 8%;
      min-width: 8px; min-height: 8px;
      background: radial-gradient(circle, #1a1a1a 40%, #0a0a0a 100%);
      border-radius: 50%;
      box-shadow: inset 0 0 4px rgba(255,255,255,0.2), 0 0 2px rgba(0,0,0,0.8);
      z-index: 2;
    }
    .coverflow-item.active .cf-disc {
      box-shadow: 0 8px 40px rgba(0,0,0,0.8), 0 0 0 3px rgba(255,255,255,0.06), inset 0 0 60px rgba(0,0,0,0.8), 0 0 46px rgba(255,85,0,0.12);
    }
    .coverflow-nav {
      position: absolute;
      top: 40%;
      transform: translateY(-50%);
      z-index: 20;
      width: 44px; height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.3);
      transition: color 0.3s;
      cursor: pointer;
      background: none;
      border: none;
    }
    .coverflow-nav:hover { color: #FF5500; }
    .coverflow-nav.prev { left: 0; }
    .coverflow-nav.next { right: 0; }
    .coverflow-fade-wrap {
      position: relative;
      /* extra vertical room so the active disc's glow/shadow isn't clipped by the
         horizontal fade mask (a mask clips to its own box on all sides) */
      padding-top: 44px;
      padding-bottom: 44px;
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 7%, black 93%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, black 7%, black 93%, transparent 100%);
    }
    /* On narrow screens only 1–2 discs show — drop the side fade so the active
       disc is never clipped, and keep the coverflow compact. */
    @media (max-width: 640px) {
      .coverflow { height: clamp(260px, 64vw, 300px); }
      .coverflow-fade-wrap { -webkit-mask-image: none; mask-image: none; padding-top: 16px; padding-bottom: 16px; }
    }

    /* Hero animated gradient — brand colours (black / orange / white) that
       shift vertically as the page scrolls (driven by --hero-shift). */
    .hero-gradient {
      --hero-shift: 26%;
      background-image: linear-gradient(168deg,
        #050505 0%,
        #120700 12%,
        #3a1400 24%,
        #99360a 36%,
        #ff5500 48%,
        #ff9a5e 55%,
        #ffe6d8 61%,
        #ff6a1f 69%,
        #5e2106 80%,
        #0a0604 92%,
        #050505 100%);
      background-size: 100% 235%;
      background-position: 50% var(--hero-shift);
      background-repeat: no-repeat;
      will-change: background-position;
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-gradient { --hero-shift: 30%; }
    }
  </style>

  <!-- Act 0 — Silence: every night starts with a single pulse in the dark -->
  <section id="act-silence" class="isolate relative bg-brand-black min-h-[92vh] flex items-center justify-center overflow-hidden">
    <div class="text-center px-6" data-act0>
      <div class="pulse-line mx-auto mb-10"></div>
      <p class="font-display text-2xl md:text-4xl lg:text-5xl font-black text-white/95">Every night starts in <span class="text-brand-orange">silence</span>.</p>
      <p class="text-gray-500 mt-6 text-xs md:text-sm uppercase tracking-[0.35em]">Scroll to start the therapy</p>
    </div>
  </section>

  <section class="isolate relative flex flex-col items-center justify-center bg-brand-black pt-28 sm:pt-32">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="hero-gradient absolute inset-0"></div>
      <!-- Higgsfield psy art: healing-frequency waves drifting behind the vinyls -->
      <div class="psy-layer absolute inset-0" aria-hidden="true"></div>
      <!-- Promo teaser layer: loads after LCP (idle callback), fades in over the
           gradient. preload="none" + deferred src keep it off the critical path. -->
      {heroVideo && (
        <video data-hero-video class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-1000"
          muted loop playsinline preload="none" aria-hidden="true">
          <source data-src={heroVideo} type="video/mp4" />
        </video>
      )}
      <!-- legibility scrim: darker at the top (behind the title), clears lower so the gradient + vinyls show -->
      <div class="absolute inset-0" style="background:linear-gradient(to bottom, rgba(5,5,7,0.5) 0%, rgba(5,5,7,0.12) 26%, rgba(5,5,7,0) 46%, rgba(5,5,7,0) 100%);"></div>
    </div>
    <div data-spotlight class="spotlight absolute inset-0 pointer-events-none z-10"></div>
    <div class="container mx-auto px-6 sm:px-8 lg:px-12 text-center z-30">
      <h1 class="font-display text-5xl md:text-7xl lg:text-9xl font-black leading-none glitch-text glitch-auto cursor-default mb-0" style="text-shadow:0 2px 34px rgba(0,0,0,0.55), 0 1px 2px rgba(0,0,0,0.6);">ZIPPY<span class="text-brand-orange">.</span></h1>
      <h2 class="font-display text-2xl md:text-4xl lg:text-6xl font-black mb-0 text-transparent bg-clip-text bg-gradient-to-r from-brand-orange to-white tracking-tight" style="filter:drop-shadow(0 2px 16px rgba(0,0,0,0.5));">HOUSE MUSIC THERAPY</h2>
      <div class="eq-bars mt-3" aria-hidden="true">
        {Array.from({ length: 24 }).map(() => <span></span>)}
      </div>

      <div id="highlights" class="relative pt-2 sm:pt-3 pb-10 sm:pb-14 z-30">
        <!-- Higgsfield photoreal record-store crates: pans sideways as you flip records -->
        <div class="store-layer" aria-hidden="true"></div>
        <div class="dust" aria-hidden="true">
          {Array.from({ length: 7 }).map(() => <span></span>)}
        </div>
        <div class="container mx-auto px-6 sm:px-8 lg:px-12">
          <div class="text-center mb-6 sm:mb-8">
            <h2 class="split-reveal font-display text-2xl md:text-3xl font-bold mb-1" style="text-shadow:0 1px 12px rgba(0,0,0,0.5);">Featured <span class="text-brand-orange">Mixes</span></h2>
            <p class="text-gray-300 text-sm" style="text-shadow:0 1px 8px rgba(0,0,0,0.6);">Listen to DJ Zippy's latest sets and mixes.</p>
          </div>
          <div class="relative px-6 sm:px-14">
            <button class="coverflow-nav prev" aria-label="Previous"><i class="fa-solid fa-chevron-left text-xl"></i></button>
            <div class="coverflow-fade-wrap">
              <div class="coverflow" id="coverflow-container">
                <div class="crate-sleeve" aria-hidden="true"><div class="crate-sleeve-inner"></div></div>
                {featuredMixes.map(m => (
                  <article class="coverflow-item text-center" data-link={m.link} data-platform={m.platform} data-title={m.title}>
                    <div class="cf-disc">
                      <div class={m.thumbnail ? 'cf-label' : 'cf-label cf-label-art'} style={m.thumbnail ? `background-image: url('${ytThumb(m.thumbnail, 'mqdefault')}');` : undefined}>
                        {!m.thumbnail && <span class="cf-label-title">ZIPPY</span>}
                        {!m.thumbnail && <span class="cf-label-sub">{m.platform.toUpperCase()}</span>}
                      </div>
                      <div class="cf-spindle"></div>
                      <i class="fa-solid fa-play cf-play-overlay"></i>
                    </div>
                    <div class="mt-3 text-xs text-gray-400 space-y-0.5">
                      <span class="block font-semibold text-white/80">{m.title}</span>
                      <span class="block text-gray-500">{m.platform.charAt(0).toUpperCase() + m.platform.slice(1)}</span>
                    </div>
                  </article>
                ))}
              </div>
            </div>
            <button class="coverflow-nav next" aria-label="Next"><i class="fa-solid fa-chevron-right text-xl"></i></button>
          </div>
          <div class="mt-16 sm:mt-20 text-center">
            <a href="/mixes" class="inline-flex items-center gap-2 text-gray-400 hover:text-brand-orange transition-colors">
              <i class="fa-solid fa-headphones"></i> Listen Now
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="marquee bg-brand-black border-y border-white/5 py-4 sm:py-5" aria-hidden="true">
    <div class="marquee__track">
      {[0, 1].map(() => ticker.map((w) => (
        <span class="inline-flex items-center gap-10">
          <span class="font-display text-lg sm:text-2xl font-black uppercase tracking-widest text-white/15">{w}</span>
          <span class="text-brand-orange text-base">&#9679;</span>
        </span>
      )))}
    </div>
  </div>

  <!-- Act 2 — Needle Drop: the moment selection becomes therapy -->
  <section id="act-needle" class="isolate relative bg-brand-black overflow-hidden">
    <div class="relative min-h-[95vh] flex items-center justify-center">
      <div class="groove-bg absolute inset-0" aria-hidden="true"></div>
      <svg class="stylus absolute top-[6%] right-[6%] w-40 md:w-64 z-10" viewBox="0 0 200 200" aria-hidden="true">
        <circle cx="170" cy="30" r="13" fill="#161616" stroke="#2e2e2e" stroke-width="3"/>
        <line x1="170" y1="30" x2="74" y2="138" stroke="#1c1c1c" stroke-width="7" stroke-linecap="round"/>
        <rect x="56" y="132" width="30" height="16" rx="4" fill="#262626" transform="rotate(-42 70 142)"/>
        <line x1="62" y1="152" x2="58" y2="163" stroke="#FF5500" stroke-width="3" stroke-linecap="round"/>
      </svg>
      <div class="relative z-10 text-center px-6 max-w-2xl">
        <h2 class="split-reveal font-display text-3xl md:text-5xl font-black mb-4">The needle <span class="text-brand-orange">drops</span></h2>
        <p class="text-gray-400 md:text-lg">Selection is the real therapy — reading the room, groove by groove, until the floor breathes as one.</p>
      </div>
      <svg class="therapy-wave absolute bottom-10 left-0 w-full h-16 z-10" viewBox="0 0 1200 80" fill="none" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0 40 Q 30 40 50 38 T 100 42 T 150 30 T 200 52 T 250 24 T 300 58 T 350 18 T 400 62 T 450 28 T 500 50 T 550 36 T 600 44 T 650 22 T 700 60 T 750 30 T 800 52 T 850 38 T 900 42 T 950 26 T 1000 56 T 1050 34 T 1100 46 T 1150 40 T 1200 40" stroke-width="2.5"/>
      </svg>
    </div>
  </section>

  <section id="dates" class="isolate relative py-8 sm:py-16 bg-brand-black overflow-hidden">
    <div class="floor-layer" aria-hidden="true"></div>
    <div class="container mx-auto px-6 sm:px-8 lg:px-12 relative z-10">
      <h2 class="split-reveal font-display text-3xl md:text-4xl font-bold mb-8 text-center">Upcoming <span class="text-brand-orange">Therapy</span></h2>
      <div class="mb-8">
        <Countdown event={upcoming[0] ?? null} />
        {heroVideo && (
          <div class="mt-4 text-center">
            <a href={heroVideo} download target="_blank" rel="noopener" data-track="promo_download"
              class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-brand-orange transition-colors">
              <i class="fa-solid fa-arrow-right rotate-90"></i> Download Promo Video (Reels / TikTok)
            </a>
          </div>
        )}
      </div>
      <div class="space-y-1 flex flex-col items-center max-w-3xl mx-auto" data-reveal>
        {homeUpcoming.length === 0 && <p class="text-gray-400 text-center">No upcoming events scheduled.</p>}
        {homeUpcoming.map(e => {
          const displayDate = e.date.split('-').reverse().join('/') + (e.time ? ` | ${e.time}` : '');
          return (
            <div class="w-full">
              <div class="flex flex-col md:flex-row items-center bg-brand-gray p-2 rounded-lg border-l-4 border-brand-orange hover:bg-white/5 transition-colors">
                <div class="md:w-2/5 text-center md:text-left mb-1 md:mb-0 flex-shrink-0">
                  <span class="block text-sm sm:text-base md:text-lg lg:text-xl font-display font-bold">{e.title.toUpperCase()}</span>
                  <span class="text-xs md:text-sm text-gray-500 uppercase tracking-widest">{e.location}</span>
                </div>
                <div class="md:flex-1 text-center md:text-left mb-1 md:mb-0 px-2 min-w-0">
                  <span class="block text-sm md:text-base lg:text-lg font-bold text-white">{e.subtitle || e.title}</span>
                  <span class="text-gray-400 text-xs md:text-sm">{displayDate}</span>
                </div>
                {e.link
                  ? <a href={e.link} target="_blank" rel="noopener noreferrer" data-track="tickets"
                      class="flex-shrink-0 bg-brand-orange hover:bg-white hover:text-brand-black text-white text-[11px] font-bold uppercase tracking-widest px-3.5 py-1.5 rounded-full transition-colors mb-1 md:mb-0 md:mr-2">
                      Get Tickets
                    </a>
                  : <a href="/#contact" data-track="booking"
                      class="flex-shrink-0 border border-white/20 text-gray-300 hover:border-brand-orange hover:text-brand-orange text-[11px] font-bold uppercase tracking-widest px-3.5 py-1.5 rounded-full transition-colors mb-1 md:mb-0 md:mr-2">
                      Book a Date
                    </a>}
              </div>
            </div>
          );
        })}
      </div>
      <div class="mt-8 text-center">
        <a href="/events" class="inline-flex items-center gap-2 text-gray-400 hover:text-brand-orange transition-colors">
          <i class="fa-solid fa-calendar"></i> View All Events & Past Highlights
        </a>
      </div>
    </div>
  </section>

  <!-- Act 4 — Afterglow: the sunrise floods in, the story asks for the next city -->
  <section id="act-afterglow" class="isolate relative overflow-hidden">
    <div class="sunrise absolute inset-0" aria-hidden="true"></div>
    <div class="relative z-10 container mx-auto px-6 text-center py-24 md:py-36">
      <h2 class="split-reveal font-display text-3xl md:text-5xl font-black mb-3">Then comes the <span class="text-brand-orange">sunrise</span>.</h2>
      <p class="text-gray-200 md:text-lg mb-8" style="text-shadow:0 1px 10px rgba(0,0,0,0.5);">Bring the therapy to your city.</p>
      <a href="#contact" data-track="booking"
        class="inline-block bg-brand-black/80 hover:bg-brand-orange text-white text-sm font-bold uppercase tracking-widest px-8 py-4 rounded-full border border-white/20 hover:border-brand-orange transition-colors">
        Book DJ Zippy
      </a>
    </div>
  </section>

  <LeadMagnet variant="inline" />
  <LeadMagnet variant="popup" />

  <script is:inline>
  function initCoverflow() {
    // === COVERFLOW === (items are server-rendered from the DB)
    var coverflowContainer = document.getElementById('coverflow-container');
    if (coverflowContainer && !coverflowContainer.dataset.cfReady) {
      coverflowContainer.dataset.cfReady = '1';
      var items = document.querySelectorAll('.coverflow-item');
      if (items.length) {
        var active = 0;
        function getGap() {
          var vw = window.innerWidth;
          if (vw < 640) return vw * 0.28;
          if (vw < 1024) return vw * 0.2;
          return Math.min(vw * 0.16, 220);
        }
        function update() {
          var gap = getGap();
          var half = Math.floor(items.length / 2);
          items.forEach(function(el, i) {
            var off = i - active;
            if (off > half) off -= items.length;
            if (off < -half) off += items.length;
            var abs = Math.abs(off);
            var tx = off * gap;
            var tz = abs === 0 ? 80 : -(abs * 140);
            // Crate effect: side records sit lower (tucked in the bin), the
            // active one stands pulled out above them.
            var tyP = abs === 0 ? -56 : -44;
            var ry = off < 0 ? 55 : off > 0 ? -55 : 0;
            var sc = abs === 0 ? 1.1 : Math.max(0.65, 0.85 - (abs - 1) * 0.15);
            var op = abs > 2 ? 0.15 : abs === 0 ? 1 : 0.5 - (abs - 1) * 0.15;
            var prevOff = parseInt(el.getAttribute('data-off') || String(i), 10);
            var delta = Math.abs(off - prevOff);
            var wrapping = delta > half;
            el.setAttribute('data-off', String(off));
            if (wrapping) {
              // Teleport instantly with no transition and invisible
              el.style.transition = 'none';
              el.style.opacity = '0';
              el.style.transform = 'translateY(' + tyP + '%) translateX(' + tx + 'px) translateZ(' + tz + 'px) rotateY(' + ry + 'deg) scale(' + sc + ')';
              el.style.zIndex = String(10 - abs);
              // Re-enable transition after paint so it fades in at new position
              requestAnimationFrame(function() {
                requestAnimationFrame(function() {
                  el.style.transition = '';
                  el.style.opacity = String(op);
                });
              });
            } else {
              el.style.transition = '';
              el.style.transform = 'translateY(' + tyP + '%) translateX(' + tx + 'px) translateZ(' + tz + 'px) rotateY(' + ry + 'deg) scale(' + sc + ')';
              el.style.zIndex = String(10 - abs);
              el.style.opacity = String(op);
            }
            if (off === 0) el.classList.add('active');
            else el.classList.remove('active');
          });
        }
        // Record-change FX: shockwave ring from the spindle, ambient hue shift
        // of the psy layer, and a pop on the newly active disc.
        function fireChangeFx() {
          var cf = document.querySelector('.coverflow');
          if (!cf || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
          var w = document.createElement('div');
          w.className = 'cf-shockwave';
          cf.appendChild(w);
          setTimeout(function() { w.remove(); }, 750);
          document.documentElement.style.setProperty('--psy-shift', (active * 16) + 'deg');
          // Step along the crate row: pan the store photo with each record
          document.documentElement.style.setProperty('--shelf-x', (((active % items.length) - items.length / 2) * 3) + '%');
          var d = items[active].querySelector('.cf-disc');
          if (d) { d.classList.remove('disc-pop'); void d.offsetWidth; d.classList.add('disc-pop'); }
          // Cardboard sleeve rises out of the crate; the disc slides out of it
          var sl = cf.querySelector('.crate-sleeve');
          if (sl) { sl.classList.remove('pull'); void sl.offsetWidth; sl.classList.add('pull'); }
        }
        items.forEach(function(el, i) {
          el.addEventListener('click', function() {
            if (active === i) {
              var link = el.getAttribute('data-link');
              if (!link) return;
              var played = window.ZippyDock && window.ZippyDock.play({
                platform: el.getAttribute('data-platform'),
                link: link,
                title: el.getAttribute('data-title'),
              });
              if (!played) window.open(link, '_blank', 'noopener,noreferrer');
            } else { active = i; update(); fireChangeFx(); }
          });
        });
        function wrap(i) { return ((i % items.length) + items.length) % items.length; }
        // Hook for the scrollytelling act: scroll position drives record flips.
        window.__cfCount = items.length;
        window.__cfGoto = function(i) {
          var n = wrap(i);
          if (n === active) return;
          active = n; update(); fireChangeFx();
        };
        var prevBtn = document.querySelector('.coverflow-nav.prev');
        var nextBtn = document.querySelector('.coverflow-nav.next');
        if (prevBtn) prevBtn.addEventListener('click', function() { active = wrap(active - 1); update(); fireChangeFx(); });
        if (nextBtn) nextBtn.addEventListener('click', function() { active = wrap(active + 1); update(); fireChangeFx(); });
        var startX = 0;
        var cfEl = document.querySelector('.coverflow');
        if (cfEl) {
          cfEl.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
          cfEl.addEventListener('touchend', function(e) {
            var diff = startX - e.changedTouches[0].clientX;
            if (Math.abs(diff) > 50) { active = wrap(diff > 0 ? active + 1 : active - 1); update(); fireChangeFx(); }
          }, { passive: true });
        }
        window.addEventListener('resize', update);
        update();
      }
    }
  }
  document.addEventListener('astro:page-load', initCoverflow);

  // Hero gradient shifts its brand colours vertically as the page scrolls down.
  function initHeroScroll() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.__heroScrollBound) { if (window.__heroApply) window.__heroApply(); return; }
    window.__heroScrollBound = true;
    var ticking = false;
    function apply() {
      ticking = false;
      var hero = document.querySelector('.hero-gradient');
      if (!hero) return;
      var y = window.scrollY || window.pageYOffset || 0;
      var p = Math.max(0, Math.min(1, y / (window.innerHeight * 1.4)));
      hero.style.setProperty('--hero-shift', (26 + p * 54) + '%');
    }
    window.__heroApply = apply;
    window.addEventListener('scroll', function() {
      if (!ticking) { ticking = true; requestAnimationFrame(apply); }
    }, { passive: true });
    apply();
  }
  document.addEventListener('astro:page-load', initHeroScroll);

  // Hero promo teaser: start the video only after the page is idle so it never
  // competes with LCP; fade it in over the gradient (which stays as fallback).
  function initHeroVideo() {
    var v = document.querySelector('[data-hero-video]');
    if (!v || v.dataset.ready) return;
    v.dataset.ready = '1';
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    function start() {
      var s = v.querySelector('source');
      if (s && !s.src) { s.src = s.getAttribute('data-src'); v.load(); }
      var p = v.play();
      if (p && p.then) p.then(function () { v.style.opacity = '0.55'; }).catch(function () {});
      else v.style.opacity = '0.55';
    }
    if ('requestIdleCallback' in window) requestIdleCallback(start, { timeout: 2500 });
    else setTimeout(start, 1200);
  }
  document.addEventListener('astro:page-load', initHeroVideo);
  </script>

  <!-- "One Night of Therapy" — scroll-driven story (GSAP ScrollTrigger + Lenis) -->
  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    function initStory() {
      const act0 = document.getElementById('act-silence');
      if (!act0 || act0.dataset.storyBound) return;
      act0.dataset.storyBound = '1';
      if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      gsap.registerPlugin(ScrollTrigger);
      const lenis = (window as any).__lenis;
      if (lenis && !(window as any).__lenisGsap) {
        (window as any).__lenisGsap = true;
        lenis.on('scroll', ScrollTrigger.update);
      }

      // Act 0 — the silence dissolves as you scroll into the night
      gsap.to('[data-act0]', {
        opacity: 0, scale: 0.92, filter: 'blur(6px)', ease: 'none',
        scrollTrigger: { trigger: '#act-silence', start: 'top top', end: 'bottom 35%', scrub: true },
      });

      // Act 1 — crate digging: pin the coverflow, scroll flips through the records
      gsap.matchMedia().add('(min-width: 768px)', () => {
        const n = (window as any).__cfCount || 0;
        if (!n) return;
        ScrollTrigger.create({
          trigger: '#highlights',
          start: 'center center',
          end: '+=' + n * 160,
          pin: true,
          anticipatePin: 1,
          onUpdate(self) {
            const idx = Math.min(n - 1, Math.floor(self.progress * n));
            if ((window as any).__cfGoto) (window as any).__cfGoto(idx);
          },
        });
      });

      // Act 2 — needle drop: groove zooms in, tonearm lowers, the waveform draws
      const wavePath = document.querySelector('.therapy-wave path') as SVGPathElement | null;
      if (wavePath) {
        const len = wavePath.getTotalLength();
        wavePath.style.strokeDasharray = String(len);
        wavePath.style.strokeDashoffset = String(len);
        gsap.timeline({
          scrollTrigger: { trigger: '#act-needle', start: 'top 70%', end: 'bottom 25%', scrub: 0.6 },
        })
          .to('.groove-bg', { scale: 1, opacity: 0.85, ease: 'none' }, 0)
          .fromTo('.stylus', { rotation: -16, y: -30 }, { rotation: 0, y: 0, ease: 'none' }, 0)
          .to(wavePath, { strokeDashoffset: 0, ease: 'none' }, 0.25);
      }

      // Act 3 — the floor: event rows land like beats
      if (document.querySelector('#dates [data-reveal] > div')) {
        gsap.from('#dates [data-reveal] > div', {
          y: 36, opacity: 0, stagger: 0.12, duration: 0.7, ease: 'power3.out',
          scrollTrigger: { trigger: '#dates', start: 'top 65%' },
        });
      }

      // Act 4 — sunrise floods upward through the gradient as you arrive
      gsap.to('.sunrise', {
        '--sunrise-y': '100%', ease: 'none',
        scrollTrigger: { trigger: '#act-afterglow', start: 'top 85%', end: 'bottom 60%', scrub: true },
      });
    }
    document.addEventListener('astro:page-load', initStory);
    document.addEventListener('astro:before-swap', () => {
      ScrollTrigger.getAll().forEach((t) => t.kill());
    });
  </script>
</Layout>
