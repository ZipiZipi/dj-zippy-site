  <style is:global>
    .coverflow {
      perspective: 600px;
      perspective-origin: 50% 50%;
      position: relative;
      height: 340px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .coverflow-item {
      position: absolute;
      top: 50%;
      width: clamp(200px, 24vw, 280px);
      transition: transform 0.7s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.5s ease;
      transform-style: preserve-3d;
      cursor: pointer;
      user-select: none;
    }
    .coverflow-item.active { cursor: default; }
    .cf-disc {
      width: clamp(160px, 20vw, 230px);
      height: clamp(160px, 20vw, 230px);
      background:
        radial-gradient(circle at center, transparent 18%, #0d0d0d 19%),
        repeating-radial-gradient(circle at center, rgba(30,30,30,1) 0px, rgba(20,20,20,1) 1px, rgba(15,15,15,1) 2px, rgba(25,25,25,1) 3px),
        linear-gradient(135deg, #111 0%, #0a0a0a 50%, #111 100%);
      border-radius: 50%;
      position: relative;
      margin: 0 auto;
      box-shadow: 0 4px 30px rgba(0,0,0,0.7), 0 0 0 2px rgba(255,255,255,0.08), 0 0 0 4px rgba(0,0,0,0.5), inset 0 0 60px rgba(0,0,0,0.8);
    }
    .cf-disc::before {
      content: '';
      position: absolute;
      inset: 2%;
      border-radius: 50%;
      background:
        repeating-radial-gradient(circle at center, transparent, transparent 1.5px, rgba(255,255,255,0.03) 2px, transparent 2.5px),
        repeating-radial-gradient(circle at center, transparent, transparent 5px, rgba(255,255,255,0.015) 5.5px, transparent 6px),
        linear-gradient(135deg, transparent 20%, rgba(255,255,255,0.07) 45%, transparent 55%, rgba(255,255,255,0.04) 80%, transparent 100%);
      pointer-events: none;
    }
    .cf-disc::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.08);
      box-shadow: inset 0 0 8px rgba(255,255,255,0.03);
      pointer-events: none;
    }
    .cf-label {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 38%; height: 38%;
      border-radius: 50%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0;
      box-shadow: 0 0 0 3px rgba(0,0,0,0.5), 0 0 15px rgba(0,0,0,0.3);
      z-index: 1;
      background-size: cover;
      background-position: center;
      overflow: hidden;
    }
    .cf-label::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: -1;
    }
    .cf-play-overlay {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      font-size: 3rem;
      color: rgba(255,255,255,0.9);
      text-shadow: 0 4px 15px rgba(0,0,0,0.8);
      opacity: 0;
      transition: opacity 0.3s;
      pointer-events: none;
      z-index: 10;
    }
    .coverflow-item.active:hover .cf-play-overlay { opacity: 1; }
    .cf-label-title {
      font-size: clamp(0.5rem, 1vw, 0.7rem);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.95);
      text-shadow: 0 1px 3px rgba(0,0,0,0.5);
      line-height: 1;
      margin-bottom: 10px;
    }
    .cf-label-sub {
      font-size: clamp(0.4rem, 0.8vw, 0.55rem);
      font-weight: 600;
      color: rgba(255,255,255,0.7);
      text-shadow: 0 1px 2px rgba(0,0,0,0.4);
      line-height: 1;
      margin-top: 10px;
    }
    .cf-spindle {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 8%; height: 8%;
      min-width: 8px; min-height: 8px;
      background: radial-gradient(circle, #1a1a1a 40%, #0a0a0a 100%);
      border-radius: 50%;
      box-shadow: inset 0 0 4px rgba(255,255,255,0.2), 0 0 2px rgba(0,0,0,0.8);
      z-index: 2;
    }
    .coverflow-item.active .cf-disc {
      box-shadow: 0 8px 40px rgba(0,0,0,0.8), 0 0 0 3px rgba(255,255,255,0.06), inset 0 0 60px rgba(0,0,0,0.8), 0 0 60px rgba(255,85,0,0.08);
    }
    .coverflow-nav {
      position: absolute;
      top: 40%;
      transform: translateY(-50%);
      z-index: 20;
      width: 44px; height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,0.3);
      transition: color 0.3s;
      cursor: pointer;
      background: none;
      border: none;
    }
    .coverflow-nav:hover { color: #FF5500; }
    .coverflow-nav.prev { left: 0; }
    .coverflow-nav.next { right: 0; }
    .coverflow-fade-wrap {
      position: relative;
      padding-top: 30px;
      padding-bottom: 30px;
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 14%, black 86%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, black 14%, black 86%, transparent 100%);
    }
  </style>

  <section class="isolate relative flex flex-col items-center justify-center bg-brand-black pt-28 sm:pt-32">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60vw] h-[60vw] bg-brand-orange/10 blur-[120px] rounded-full"></div>
    </div>
    <div class="container mx-auto px-6 sm:px-8 lg:px-12 text-center z-30">
      <h1 class="font-display text-5xl md:text-7xl lg:text-9xl font-black leading-none glitch-text cursor-default mb-0">ZIPPY</h1>
      <h2 class="font-display text-2xl md:text-4xl lg:text-6xl font-black mb-0 text-transparent bg-clip-text bg-gradient-to-r from-brand-orange to-white tracking-tight">HOUSE MUSIC THERAPY</h2>

      <div id="highlights" class="relative pt-6 sm:pt-10 pb-10 sm:pb-14 z-30">
        <div class="container mx-auto px-6 sm:px-8 lg:px-12">
          <div class="text-center mb-12 sm:mb-16">
            <h2 class="font-display text-2xl md:text-3xl font-bold mb-1">Featured <span class="text-brand-orange">Mixes</span></h2>
            <p class="text-gray-400 text-sm">Listen to DJ Zippy's latest sets and mixes.</p>
          </div>
          <div class="relative px-10 sm:px-14">
            <button class="coverflow-nav prev" aria-label="Previous"><i class="fa-solid fa-chevron-left text-xl"></i></button>
            <div class="coverflow-fade-wrap">
              <div class="coverflow" id="coverflow-container"></div>
            </div>
            <button class="coverflow-nav next" aria-label="Next"><i class="fa-solid fa-chevron-right text-xl"></i></button>
          </div>
          <div class="mt-16 sm:mt-20 text-center">
            <a href="/mixes" class="inline-flex items-center gap-2 text-gray-400 hover:text-brand-orange transition-colors">
              <i class="fa-solid fa-headphones"></i> Listen Now
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="dates" class="isolate relative py-8 sm:py-16 bg-brand-black">
    <div class="container mx-auto px-6 sm:px-8 lg:px-12">
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-8 text-center">Upcoming <span class="text-brand-orange">Therapy</span></h2>
      <div id="upcoming-events-container" class="space-y-1 flex flex-col items-center max-w-3xl mx-auto"></div>
      <div class="mt-8 text-center">
        <a href="/events" class="inline-flex items-center gap-2 text-gray-400 hover:text-brand-orange transition-colors">
          <i class="fa-solid fa-calendar"></i> View All Events & Past Highlights
        </a>
      </div>
    </div>
  </section>

