  <script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    // === COVERFLOW ===
    var coverflowContainer = document.getElementById('coverflow-container');
    if (coverflowContainer && window.appData && window.appData.mixes) {
      var featuredMixes = window.appData.mixes.filter(function(m) { return m.featured; });
      if (featuredMixes.length === 0) featuredMixes = window.appData.mixes.slice(0, 5);
      var cfHtml = '';
      featuredMixes.forEach(function(m) {
        var labelBg = m.thumbnail ? 'style="background-image: url(\'' + m.thumbnail + '\');"' : '';
        var labelClass = m.thumbnail ? 'cf-label' : 'cf-label bg-brand-orange';
        var labelContent = m.thumbnail ? '' : '<span class="cf-label-title">ZIPPY</span><span class="cf-label-sub">' + m.platform.toUpperCase() + '</span>';
        cfHtml += '<article class="coverflow-item text-center" data-link="' + m.link + '">' +
          '<div class="cf-disc">' +
          '<div class="' + labelClass + '" ' + labelBg + '>' + labelContent + '</div>' +
          '<div class="cf-spindle"></div>' +
          '<i class="fa-solid fa-play cf-play-overlay"></i>' +
          '</div>' +
          '<div class="mt-3 text-xs text-gray-400 space-y-0.5">' +
          '<span class="block font-semibold text-white/80">' + m.title + '</span>' +
          '<span class="block text-gray-500">' + m.platform.charAt(0).toUpperCase() + m.platform.slice(1) + '</span>' +
          '</div></article>';
      });
      coverflowContainer.innerHTML = cfHtml;

      var items = document.querySelectorAll('.coverflow-item');
      if (items.length) {
        var active = 0;
        function getGap() {
          var vw = window.innerWidth;
          if (vw < 640) return vw * 0.28;
          if (vw < 1024) return vw * 0.2;
          return Math.min(vw * 0.16, 220);
        }
        function update() {
          var gap = getGap();
          var half = Math.floor(items.length / 2);
          items.forEach(function(el, i) {
            var off = i - active;
            if (off > half) off -= items.length;
            if (off < -half) off += items.length;
            var abs = Math.abs(off);
            var tx = off * gap;
            var tz = abs === 0 ? 80 : -(abs * 140);
            var ry = off < 0 ? 55 : off > 0 ? -55 : 0;
            var sc = abs === 0 ? 1.1 : Math.max(0.65, 0.85 - (abs - 1) * 0.15);
            var op = abs > 2 ? 0.15 : abs === 0 ? 1 : 0.5 - (abs - 1) * 0.15;
            var prevOff = parseInt(el.getAttribute('data-off') || String(i), 10);
            var delta = Math.abs(off - prevOff);
            var wrapping = delta > half;
            el.setAttribute('data-off', String(off));
            if (wrapping) {
              // Teleport instantly with no transition and invisible
              el.style.transition = 'none';
              el.style.opacity = '0';
              el.style.transform = 'translateY(-50%) translateX(' + tx + 'px) translateZ(' + tz + 'px) rotateY(' + ry + 'deg) scale(' + sc + ')';
              el.style.zIndex = String(10 - abs);
              // Re-enable transition after paint so it fades in at new position
              requestAnimationFrame(function() {
                requestAnimationFrame(function() {
                  el.style.transition = '';
                  el.style.opacity = String(op);
                });
              });
            } else {
              el.style.transition = '';
              el.style.transform = 'translateY(-50%) translateX(' + tx + 'px) translateZ(' + tz + 'px) rotateY(' + ry + 'deg) scale(' + sc + ')';
              el.style.zIndex = String(10 - abs);
              el.style.opacity = String(op);
            }
            if (off === 0) el.classList.add('active');
            else el.classList.remove('active');
          });
        }
        items.forEach(function(el, i) {
          el.addEventListener('click', function() {
            if (active === i) {
              var link = el.getAttribute('data-link');
              if (link) window.open(link, '_blank', 'noopener,noreferrer');
            } else { active = i; update(); }
          });
        });
        function wrap(i) { return ((i % items.length) + items.length) % items.length; }
        var prevBtn = document.querySelector('.coverflow-nav.prev');
        var nextBtn = document.querySelector('.coverflow-nav.next');
        if (prevBtn) prevBtn.addEventListener('click', function() { active = wrap(active - 1); update(); });
        if (nextBtn) nextBtn.addEventListener('click', function() { active = wrap(active + 1); update(); });
        var startX = 0;
        var cfEl = document.querySelector('.coverflow');
        if (cfEl) {
          cfEl.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, { passive: true });
          cfEl.addEventListener('touchend', function(e) {
            var diff = startX - e.changedTouches[0].clientX;
            if (Math.abs(diff) > 50) { active = wrap(diff > 0 ? active + 1 : active - 1); update(); }
          }, { passive: true });
        }
        window.addEventListener('resize', update);
        update();
      }
    }

    // === UPCOMING EVENTS ===
    if (window.zippyEvents) {
      var datesContainer = document.getElementById('upcoming-events-container');
      if (datesContainer) {
        var upcoming = window.zippyEvents.filter(function(e) { return e.status === 'upcoming'; });
        upcoming.sort(function(a, b) { return new Date(a.date) - new Date(b.date); });
        var evHtml = '';
        upcoming.slice(0, 4).forEach(function(e) {
          var displayDate = e.date.split('-').reverse().join('/') + (e.time ? ' | ' + e.time : '');
          evHtml += '<div class="w-full">' +
            '<div class="flex flex-col md:flex-row items-center bg-brand-gray p-2 rounded-lg border-l-4 border-brand-orange hover:bg-white/5 transition-colors">' +
            '<div class="md:w-2/5 text-center md:text-left mb-1 md:mb-0 flex-shrink-0">' +
            '<span class="block text-sm sm:text-base md:text-lg lg:text-xl font-display font-bold">' + e.title.toUpperCase() + '</span>' +
            '<span class="text-xs md:text-sm text-gray-500 uppercase tracking-widest">' + e.location + '</span>' +
            '</div>' +
            '<div class="md:w-3/5 text-center md:text-left mb-1 md:mb-0 px-2 flex-shrink-0">' +
            '<span class="block text-sm md:text-base lg:text-lg font-bold text-white">' + (e.subtitle || e.title) + '</span>' +
            '<span class="text-gray-400 text-xs md:text-sm">' + displayDate + '</span>' +
            '</div></div></div>';
        });
        datesContainer.innerHTML = evHtml || '<p class="text-gray-400 text-center">No upcoming events scheduled.</p>';
      }
    }
  });
  </script>
</Layout>
