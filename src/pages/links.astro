---
// Links page - standalone, no nav or footer
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>DJ Zippy | Official Links & Socials</title>
    <meta name="description" content="Official links for Zippy (DJ Zippy). Connect with House Music Therapy, tour dates, Spotify, SoundCloud, Deezer, and Resident Advisor profiles. Based in Belgrade, Serbia." />
    <link rel="canonical" href="https://zippydj.com/links" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <!-- Open Graph -->
    <meta property="og:title" content="DJ Zippy | Official Links & Socials" />
    <meta property="og:description" content="All official DJ Zippy links — streaming, socials, events and bookings. House Music Therapy from Belgrade, Serbia." />
    <meta property="og:image" content="https://zippydj.com/images/dj-zippy-house-music-dj.webp" />
    <meta property="og:url" content="https://zippydj.com/links" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DJ Zippy" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="DJ Zippy | Official Links & Socials" />
    <meta name="twitter:description" content="All official DJ Zippy links — streaming, socials, events and bookings." />
    <meta name="twitter:image" content="https://zippydj.com/images/dj-zippy-house-music-dj.webp" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;700;900&family=Inter:wght@300;400;600&display=swap" />
    <link
      href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;700;900&family=Inter:wght@300;400;600&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;700;900&family=Inter:wght@300;400;600&display=swap" rel="stylesheet" /></noscript>
    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/images/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <link rel="shortcut icon" href="/images/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Zippy" />
    <!-- Analytics (Meta Pixel + GTM) — stubs queue events now, third-party scripts
         load on first interaction (or a 3.5s fallback) so they never block paint. -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      !function(f,b,e,v,n){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[]}(window,document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init','3891455414321405');
      fbq('track','PageView');
      (function(){
        var done = false;
        function loadThirdParty(){
          if (done) return; done = true;
          var fb = document.createElement('script');
          fb.async = true; fb.src = 'https://connect.facebook.net/en_US/fbevents.js';
          document.head.appendChild(fb);
          window.dataLayer.push({'gtm.start': new Date().getTime(), event: 'gtm.js'});
          var gtm = document.createElement('script');
          gtm.async = true; gtm.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-KLGKHMGM';
          document.head.appendChild(gtm);
        }
        ['pointerdown','keydown','touchstart','scroll'].forEach(function(ev){
          addEventListener(ev, loadThirdParty, { once: true, passive: true });
        });
        setTimeout(loadThirdParty, 3500);
      })();
    </script>
    <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=3891455414321405&ev=PageView&noscript=1" /></noscript>
    <link rel="stylesheet" href="/fonts/fa/fa-subset.css" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --orange: #ff5500;
      }

      html { overflow-x: hidden; }
      body {
        background: #000;
        color: #fff;
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding: 0;
        position: relative;
        overflow-x: hidden;
      }

      /* === Background video === */
      .bg-video {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        height: 100dvh;
        object-fit: cover;
        object-position: center;
        z-index: -2;
        pointer-events: none;
      }
      .bg-overlay {
        position: fixed;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        background:
          radial-gradient(130% 90% at 50% 0%, rgba(0,0,0,0.30), transparent 55%),
          linear-gradient(180deg,
            rgba(8,8,10,0.62) 0%,
            rgba(8,8,10,0.40) 30%,
            rgba(8,8,10,0.46) 64%,
            rgba(4,4,6,0.86) 100%);
        backdrop-filter: saturate(115%);
        -webkit-backdrop-filter: saturate(115%);
      }

      main {
        width: 100%;
        max-width: 488px;          /* ~440 card area + 24px gutter each side */
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 30px;
        padding: 84px 24px 56px;   /* gutter lives here, so cards never touch edges */
        position: relative;
        z-index: 1;
      }
      @media (min-width: 640px) {
        main { max-width: 496px; padding: 108px 28px 64px; }
      }

      /* === Profile header === */
      header { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 18px; }
      .avatar-ring {
        padding: 3px;
        border-radius: 50%;
        background: conic-gradient(from 210deg, var(--orange), #ff8a4c, var(--orange));
        box-shadow: 0 14px 44px rgba(0,0,0,0.6), 0 0 30px rgba(255,85,0,0.18);
      }
      header img {
        display: block;
        width: 108px; height: 108px;
        border-radius: 50%;
        border: 3px solid rgba(8,8,10,0.9);
        object-fit: cover;
      }
      header h1 {
        font-family: 'Unbounded', sans-serif;
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        text-shadow: 0 2px 24px rgba(0,0,0,0.6);
      }
      header p {
        color: #d8d8de;
        font-size: 1.05rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        text-shadow: 0 2px 16px rgba(0,0,0,0.7);
      }

      section { width: 100%; display: flex; flex-direction: column; gap: 11px; }
      .section-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-weight: 700;
        margin-bottom: 6px;
        padding-left: 4px;
        color: rgba(255,255,255,0.5);
        text-shadow: 0 1px 10px rgba(0,0,0,0.7);
      }

      /* === Glass cards === */
      a.link-primary,
      a.link-secondary {
        display: flex;
        align-items: center;
        gap: 16px;
        width: 100%;
        text-decoration: none;
        border-radius: 15px;
        -webkit-backdrop-filter: blur(16px) saturate(135%);
        backdrop-filter: blur(16px) saturate(135%);
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
                    border-color 0.4s ease, background 0.4s ease, box-shadow 0.4s ease;
      }

      a.link-primary {
        padding: 16px 22px;
        font-weight: 500;
        color: #fff;
        background: rgba(22, 22, 26, 0.46);
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 6px 26px rgba(0, 0, 0, 0.38), inset 0 1px 0 rgba(255,255,255,0.05);
      }
      a.link-primary:hover {
        transform: translateY(-2px);
        background: rgba(30, 25, 23, 0.58);
        border-color: rgba(255, 85, 0, 0.55);
        box-shadow: 0 14px 38px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 85, 0, 0.18), 0 0 30px rgba(255, 85, 0, 0.12);
      }
      a.link-primary i { color: var(--orange); width: 22px; font-size: 1.1rem; flex-shrink: 0; text-align: center; }

      a.link-secondary {
        padding: 13px 22px;
        font-size: 0.9rem;
        font-weight: 500;
        color: #e2e2e7;
        background: rgba(14, 14, 17, 0.42);
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 4px 18px rgba(0, 0, 0, 0.3);
      }
      a.link-secondary:hover {
        transform: translateY(-2px);
        color: #fff;
        border-color: rgba(255, 255, 255, 0.28);
        background: rgba(22, 22, 26, 0.55);
      }
      a.link-secondary i { width: 20px; flex-shrink: 0; text-align: center; color: #cfcfd6; }

      /* === Site nav (minimal) === */
      a.link-site {
        display: flex;
        align-items: center;
        gap: 13px;
        width: 100%;
        padding: 9px 16px;
        font-size: 0.875rem;
        font-weight: 500;
        color: rgba(255,255,255,0.6);
        text-decoration: none;
        border-radius: 11px;
        transition: color 0.3s, background 0.3s;
      }
      a.link-site:hover { color: #fff; background: rgba(255,255,255,0.06); }
      a.link-site i { width: 16px; flex-shrink: 0; text-align: center; }
      a.link-site .arrow { margin-left: auto; font-size: 0.75rem; opacity: 0; transition: opacity 0.3s, transform 0.3s; transform: translateX(-4px); }
      a.link-site:hover .arrow { opacity: 1; transform: translateX(0); }

      .divider {
        width: 56px;
        height: 1px;
        border: none;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.22), transparent);
        margin: 2px auto;
      }

      footer { text-align: center; display: flex; flex-direction: column; gap: 6px; padding-top: 12px; }
      footer p, footer a { font-size: 0.8rem; color: rgba(255,255,255,0.45); text-decoration: none; }
      footer a:hover { color: #fff; }

      /* === Subtle entrance === */
      @keyframes rise {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: none; }
      }
      main > * { animation: rise 0.7s cubic-bezier(0.22, 1, 0.36, 1) both; }
      main > *:nth-child(1) { animation-delay: 0.04s; }
      main > *:nth-child(2) { animation-delay: 0.12s; }
      main > *:nth-child(3) { animation-delay: 0.18s; }
      main > *:nth-child(4) { animation-delay: 0.24s; }
      main > *:nth-child(5) { animation-delay: 0.30s; }
      main > *:nth-child(6) { animation-delay: 0.36s; }
      main > *:nth-child(7) { animation-delay: 0.42s; }

      @media (prefers-reduced-motion: reduce) {
        main > * { animation: none; }
        a.link-primary, a.link-secondary { transition: border-color 0.3s, background 0.3s; }
        a.link-primary:hover, a.link-secondary:hover { transform: none; }
      }
    </style>
  </head>
  <body>
    <!-- GTM noscript -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KLGKHMGM" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <!-- Background video -->
    <video
      class="bg-video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
      poster="/images/dj-zippy-house-music-dj.webp"
    >
      <source src="/videos/links-bg.mp4" type="video/mp4" />
    </video>
    <div class="bg-overlay" aria-hidden="true"></div>

    <main>

      <!-- Profile Header -->
      <header>
        <div class="avatar-ring">
          <img
            src="/images/dj-zippy-house-music-dj.webp"
            alt="Zippy (DJ Zippy) - House Music Therapy Profile"
            loading="lazy"
          />
        </div>
        <div>
          <h1>Zippy</h1>
          <p>House Music Therapy</p>
        </div>
      </header>

      <!-- Main Links -->
      <section aria-label="Main Links">
        <p class="section-label">Stream & Follow</p>

        <a href="https://zippydj.com" class="link-primary">
          <i class="fa-solid fa-globe"></i>
          <span>Official Website</span>
        </a>

        <a href="https://www.instagram.com/zovumezippy" target="_blank" rel="me noopener noreferrer" class="link-primary">
          <i class="fa-brands fa-instagram"></i>
          <span>Instagram</span>
        </a>

        <a href="https://www.youtube.com/@zovumezippy" target="_blank" rel="me noopener noreferrer" class="link-primary">
          <i class="fa-brands fa-youtube"></i>
          <span>Watch on YouTube</span>
        </a>

        <a href="https://www.mixcloud.com/zovumezippy/" target="_blank" rel="me noopener noreferrer" class="link-primary">
          <i class="fa-brands fa-mixcloud"></i>
          <span>Latest Mixes (MixCloud)</span>
        </a>

        <a href="https://open.spotify.com/user/31aj2g4yokqhpoxwkpo5odxegsle" target="_blank" rel="me noopener noreferrer" class="link-primary">
          <i class="fa-brands fa-spotify"></i>
          <span>Spotify</span>
        </a>
      </section>

      <hr class="divider" />

      <!-- Secondary Links -->
      <section aria-label="Secondary Links">
        <p class="section-label">Also on</p>

        <a href="https://soundcloud.com/zovumezippy" target="_blank" rel="me noopener noreferrer" class="link-secondary">
          <i class="fa-brands fa-soundcloud"></i>
          <span>SoundCloud</span>
        </a>

        <a href="https://www.deezer.com/en/profile/2582254702" target="_blank" rel="me noopener noreferrer" class="link-secondary">
          <i class="fa-brands fa-deezer"></i>
          <span>Deezer</span>
        </a>

        <a href="https://www.tiktok.com/@zovumezippy" target="_blank" rel="me noopener noreferrer" class="link-secondary">
          <i class="fa-brands fa-tiktok"></i>
          <span>TikTok</span>
        </a>

        <a href="https://ra.co/dj/zippy-2" target="_blank" rel="me noopener noreferrer" class="link-secondary">
          <i class="fa-solid fa-square-poll-vertical"></i>
          <span>Resident Advisor</span>
        </a>
      </section>

      <hr class="divider" />

      <!-- Site Navigation -->
      <section aria-label="Site Navigation">
        <p class="section-label">Explore the site</p>

        <a href="/events" class="link-site">
          <i class="fa-solid fa-calendar"></i>
          <span>Events & Performances</span>
          <i class="fa-solid fa-arrow-right arrow"></i>
        </a>

        <a href="/about" class="link-site">
          <i class="fa-solid fa-user"></i>
          <span>About DJ Zippy</span>
          <i class="fa-solid fa-arrow-right arrow"></i>
        </a>

        <a href="/mixes" class="link-site">
          <i class="fa-solid fa-music"></i>
          <span>Mixes & Playlists</span>
          <i class="fa-solid fa-arrow-right arrow"></i>
        </a>

        <a href="/#contact" class="link-site">
          <i class="fa-solid fa-envelope"></i>
          <span>Bookings / Contact</span>
          <i class="fa-solid fa-arrow-right arrow"></i>
        </a>
      </section>

      <!-- Footer -->
      <footer>
        <p>&copy; 2025 Zippy</p>
        <a href="https://zippydj.com">Visit Website</a>
      </footer>

    </main>
    <!-- Google Ads -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-975400552"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-975400552');
      // Conversion event removed from page load — fire it on a real action instead.
    </script>
  </body>
</html>
