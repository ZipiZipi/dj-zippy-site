    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: #000;
        color: #fff;
        font-family: 'Inter', sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding: 48px 24px;
      }
      main {
        width: 100%;
        max-width: 448px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 32px;
      }
      header { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 16px; }
      header img {
        width: 96px; height: 96px;
        border-radius: 50%;
        border: 1px solid #ff5500;
        object-fit: cover;
        box-shadow: 0 8px 30px rgba(0,0,0,0.5);
      }
      header h1 { font-size: 1.875rem; font-weight: 700; letter-spacing: -0.02em; }
      header p { color: #9ca3af; font-size: 1.125rem; font-weight: 500; }
      section { width: 100%; display: flex; flex-direction: column; gap: 12px; }
      .section-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 700;
        margin-bottom: 4px;
      }
      .label-primary { color: #6b7280; }
      .label-secondary { color: #4b5563; }
      a.link-primary {
        display: flex;
        align-items: center;
        gap: 16px;
        width: 100%;
        background: #1f1f1f;
        border: 1px solid rgba(255,85,0,0.4);
        border-radius: 8px;
        padding: 16px 24px;
        font-weight: 500;
        color: #fff;
        text-decoration: none;
        transition: border-color 0.3s, color 0.3s;
      }
      a.link-primary:hover { border-color: #ff5500; color: #ff5500; }
      a.link-primary i { color: #ff5500; width: 20px; flex-shrink: 0; }
      a.link-secondary {
        display: flex;
        align-items: center;
        gap: 16px;
        width: 100%;
        background: #161616;
        border: 1px solid rgba(63,63,70,0.5);
        border-radius: 8px;
        padding: 12px 24px;
        font-size: 0.875rem;
        font-weight: 500;
        color: #d1d5db;
        text-decoration: none;
        transition: border-color 0.3s, color 0.3s;
      }
      a.link-secondary:hover { border-color: #71717a; color: #fff; }
      a.link-secondary i { width: 20px; flex-shrink: 0; color: #d1d5db; }
      a.link-site {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
        padding: 8px 16px;
        font-size: 0.875rem;
        font-weight: 500;
        color: #6b7280;
        text-decoration: none;
        transition: color 0.3s;
      }
      a.link-site:hover { color: #fff; }
      a.link-site i { width: 16px; flex-shrink: 0; }
      a.link-site .arrow { margin-left: auto; font-size: 0.75rem; opacity: 0; transition: opacity 0.3s; }
      a.link-site:hover .arrow { opacity: 1; }
      hr { border: none; border-top: 1px solid rgba(255,255,255,0.1); width: 100%; }
      footer { text-align: center; display: flex; flex-direction: column; gap: 8px; padding-top: 16px; }
      footer p, footer a { font-size: 0.875rem; color: #6b7280; text-decoration: none; }
      footer a:hover { color: #fff; }
    </style>
  </head>
  <body>
    <!-- GTM noscript -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KLGKHMGM" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <main>

      <!-- Profile Header -->
      <header>
        <img
          src="/images/dj-zippy-house-music-dj.webp"
          alt="Zippy (DJ Zippy) - House Music Therapy Profile"
          loading="lazy"
        />
        <div>
          <h1>Zippy</h1>
          <p>House Music Therapy</p>
        </div>
      </header>

      <!-- Main Links -->
      <section aria-label="Main Links">
        <p class="section-label label-primary">Stream & Follow</p>

        <a href="https://zippydj.com" class="link-primary">
          <i class="fa-solid fa-globe"></i>
          <span>Official Website</span>
        </a>

        <a href="https://www.instagram.com/zovumezippy" target="_blank" rel="me noopener noreferrer" class="link-primary">
          <i class="fa-brands fa-instagram"></i>
          <span>Instagram</span>
        </a>

        <a href="https://www.youtube.com/@zovumezippy" target="_blank" rel="me noopener noreferrer" class="link-primary">
          <i class="fa-brands fa-youtube"></i>
          <span>Watch on YouTube</span>
        </a>

        <a href="https://www.mixcloud.com/zovumezippy/" target="_blank" rel="me noopener noreferrer" class="link-primary">
          <i class="fa-brands fa-mixcloud"></i>
          <span>Latest Mixes (MixCloud)</span>
        </a>

        <a href="https://open.spotify.com/user/31aj2g4yokqhpoxwkpo5odxegsle" target="_blank" rel="me noopener noreferrer" class="link-primary">
          <i class="fa-brands fa-spotify"></i>
          <span>Spotify</span>
        </a>
      </section>

      <hr />

      <!-- Secondary Links -->
      <section aria-label="Secondary Links">
        <p class="section-label label-secondary">Also on</p>

        <a href="https://soundcloud.com/zovumezippy" target="_blank" rel="me noopener noreferrer" class="link-secondary">
          <i class="fa-brands fa-soundcloud"></i>
          <span>SoundCloud</span>
        </a>

        <a href="https://www.tiktok.com/@zovumezippy" target="_blank" rel="me noopener noreferrer" class="link-secondary">
          <i class="fa-brands fa-tiktok"></i>
          <span>TikTok</span>
        </a>

        <a href="https://ra.co/dj/zippy-2" target="_blank" rel="me noopener noreferrer" class="link-secondary">
          <i class="fa-solid fa-square-poll-vertical"></i>
          <span>Resident Advisor</span>
        </a>
      </section>

      <hr />

      <!-- Site Navigation -->
      <section aria-label="Site Navigation">
        <p class="section-label label-secondary">Explore the site</p>

        <a href="/events" class="link-site">
          <i class="fa-solid fa-calendar"></i>
          <span>Events & Performances</span>
          <i class="fa-solid fa-arrow-right arrow"></i>
        </a>

        <a href="/about" class="link-site">
          <i class="fa-solid fa-user"></i>
          <span>About DJ Zippy</span>
          <i class="fa-solid fa-arrow-right arrow"></i>
        </a>

        <a href="/mixes" class="link-site">
          <i class="fa-solid fa-music"></i>
          <span>Mixes & Playlists</span>
          <i class="fa-solid fa-arrow-right arrow"></i>
        </a>

        <a href="/#contact" class="link-site">
          <i class="fa-solid fa-envelope"></i>
          <span>Bookings / Contact</span>
          <i class="fa-solid fa-arrow-right arrow"></i>
        </a>
      </section>

      <!-- Footer -->
      <footer>
        <p>&copy; 2025 Zippy</p>
        <a href="https://zippydj.com">Visit Website</a>
      </footer>

    </main>
