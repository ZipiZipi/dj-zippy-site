---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { getEvents, dateParts } from '../lib/content';

const db = (Astro.locals as any).runtime?.env?.DB;
const { upcoming, past } = await getEvents(db);

const musicEventSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://zippydj.com/events#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://zippydj.com/" },
        { "@type": "ListItem", "position": 2, "name": "Events", "item": "https://zippydj.com/events" }
      ]
    },
    ...upcoming.map(e => ({
      "@type": "MusicEvent",
      "@id": `https://zippydj.com/events#${e.slug}`,
      "name": `${e.title} — ${e.subtitle || 'House Music Therapy'}`,
      "startDate": e.time ? `${e.date}T${e.time.split(' - ')[0]}:00` : e.date,
      "endDate": e.time && e.time.includes(' - ') ? `${e.date}T${e.time.split(' - ')[1]}:00` : undefined,
      "eventStatus": "https://schema.org/EventScheduled",
      "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
      "location": {
        "@type": "Place",
        "name": e.title,
        "address": {
          "@type": "PostalAddress",
          "addressLocality": e.location,
          "addressCountry": e.country
        }
      },
      "performer": {
        "@type": ["Person","MusicGroup"],
        "@id": "https://zippydj.com/#person",
        "name": "DJ Zippy",
        "alternateName": "Zippy"
      },
      "organizer": {
        "@type": "Organization",
        "@id": "https://zippydj.com/#organization",
        "name": "DJ Zippy"
      },
      "url": "https://zippydj.com/events",
      "image": "https://zippydj.com/images/dj-zippy-house-music-dj.webp",
      "description": `DJ Zippy (Zippy) performing live at ${e.title} in ${e.location}. House Music Therapy.`
    }))
  ]
};
---

<Layout
  title="DJ Zippy Events | Live Shows & Festival Performances"
  description="Explore DJ Zippy's live performances, festival appearances, and club nights across Serbia including Exit Festival and Belgrade events."
  activePage="events"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(musicEventSchema)} />

  <section id="upcoming" class="isolate relative bg-brand-black pt-24 sm:pt-28 pb-16 overflow-hidden">
    <div class="aurora absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60vw] h-[60vw] rounded-full pointer-events-none"></div>
    <div class="container mx-auto px-6 sm:px-8 lg:px-12 z-30 relative">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-gray-400">
          <li><a href="/" class="hover:text-brand-orange transition-colors">Home</a></li>
          <li><span class="mx-2">/</span></li>
          <li class="text-white">Events</li>
        </ol>
      </nav>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-2">DJ Zippy</h1>
      <h2 class="font-display font-black leading-tight mb-4 text-brand-orange">Live Events & Festival Performances</h2>
      <p class="text-gray-400 text-lg md:text-xl max-w-2xl mb-10">From intimate club nights to major festival stages. House Music Therapy live.</p>
      <div class="flex items-center gap-4 mb-6">
        <div class="w-2 h-8 bg-brand-orange"></div>
        <h3 class="font-display text-2xl md:text-3xl font-bold">Upcoming <span class="text-brand-orange">Events</span></h3>
      </div>
      <div class="space-y-3" data-reveal>
        {upcoming.length === 0 && <p class="text-gray-400">No upcoming events scheduled.</p>}
        {upcoming.map(e => {
          const { day, month, year } = dateParts(e.date);
          return (
            <article class="flex items-center gap-4 sm:gap-6 border-l-4 border-brand-orange bg-brand-gray rounded-r-lg p-4 hover:bg-white/5 transition-colors">
              <div class="flex-shrink-0 text-center min-w-[4rem]">
                <span class="block font-display font-bold text-brand-orange text-xl leading-none">{day}</span>
                <span class="block text-xs text-gray-400 uppercase tracking-widest">{month}</span>
                <span class="block text-xs text-gray-500">{year}</span>
              </div>
              <div class="w-px h-10 bg-white/10 flex-shrink-0"></div>
              <div class="flex-1 min-w-0">
                <h4 class="font-display font-bold text-white text-base sm:text-lg leading-tight">{e.title}</h4>
                <p class="text-gray-400 text-sm"><i class="fa-solid fa-location-dot mr-1 text-brand-orange"></i>{e.location}{e.time ? ` · ${e.time}` : ''}</p>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <section id="past" class="isolate relative py-16 sm:py-20 bg-brand-black border-t border-white/5">
    <div class="container mx-auto px-6 sm:px-8 lg:px-12">
      <div class="flex items-center gap-4 mb-10">
        <div class="w-2 h-8 bg-white/30"></div>
        <h2 class="font-display text-3xl md:text-4xl font-bold">Past <span class="text-gray-400">Highlights</span></h2>
      </div>
      <div class="space-y-3" data-reveal>
        {past.map(e => {
          const { day, month, year } = dateParts(e.date);
          if (e.featured) {
            return (
              <article class="relative flex items-center gap-4 sm:gap-6 border-l-4 border-brand-orange bg-brand-gray rounded-r-lg p-4 sm:p-5 hover:bg-white/5 transition-colors">
                <span class="absolute top-2 right-3 inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-wider text-brand-orange">
                  <i class="fa-solid fa-star"></i> Highlight
                </span>
                <div class="flex-shrink-0 text-center min-w-[4rem]">
                  <span class="block font-display font-bold text-brand-orange text-xl leading-none">{day}</span>
                  <span class="block text-xs text-gray-400 uppercase tracking-widest">{month}</span>
                  <span class="block text-xs text-gray-500">{year}</span>
                </div>
                <div class="w-px h-10 bg-white/10 flex-shrink-0"></div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-display font-bold text-white text-base sm:text-lg leading-tight">{e.title}</h3>
                  <p class="text-gray-400 text-sm"><i class="fa-solid fa-location-dot mr-1 text-brand-orange"></i>{e.location}{e.subtitle ? ` · ${e.subtitle}` : ''}</p>
                </div>
              </article>
            );
          }
          return (
            <article class="flex items-center gap-4 sm:gap-6 border-l-2 border-brand-gray bg-brand-dark rounded-r-lg p-4 hover:border-white/30 transition-colors">
              <div class="flex-shrink-0 text-center min-w-[4rem]">
                <span class="block font-display font-bold text-gray-400 text-lg leading-none">{day}</span>
                <span class="block text-xs text-gray-500 uppercase tracking-widest">{month}</span>
                <span class="block text-xs text-gray-600">{year}</span>
              </div>
              <div class="w-px h-8 bg-white/5 flex-shrink-0"></div>
              <div class="flex-1 min-w-0">
                <h3 class="font-display font-bold text-gray-300 text-sm sm:text-base leading-tight">{e.title}</h3>
                <p class="text-gray-500 text-xs sm:text-sm"><i class="fa-solid fa-location-dot mr-1"></i>{e.location}{e.subtitle ? ` · ${e.subtitle}` : ''}</p>
              </div>
            </article>
          );
        })}
      </div>
      <div class="mt-12 text-center">
        <a href="/" class="inline-flex items-center gap-2 text-gray-400 hover:text-brand-orange transition-colors">
          <i class="fa-solid fa-arrow-left"></i> Back to Homepage
        </a>
      </div>
    </div>
  </section>
</Layout>
