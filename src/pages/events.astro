---
import Layout from '../layouts/Layout.astro';

const events = [
  { id: "event-raybar-2026-05-23", date: "2026-05-23", time: "20:00 - 01:00", title: "RayBar", subtitle: "House Music Therapy", location: "Novi Sad", country: "RS", status: "upcoming" },
  { id: "event-kc-lab-2026-05-09", date: "2026-05-09", time: "20:00 - 01:00", title: "KC Lab", subtitle: "House Music Therapy", location: "Novi Sad", country: "RS", status: "upcoming" },
  { id: "event-lazino-tele-2026-05-02", date: "2026-05-02", time: "22:00 - 03:00", title: "Lazino Tele", subtitle: "Millenial Shuffle", location: "Novi Sad", country: "RS", status: "upcoming" },
  { id: "event-raybar-2026-04-25", date: "2026-04-25", time: "20:00 - 01:00", title: "RayBar", subtitle: "House Music Therapy", location: "Novi Sad", country: "RS", status: "upcoming" },
  { id: "event-lazino-tele-2026", date: "2026-03-27", time: "22:00 - 03:00", title: "Lazino Tele", subtitle: "Millenial Shuffle", location: "Novi Sad", country: "RS", status: "past" },
  { id: "event-krivi-put-2026", date: "2026-03-21", time: "20:00 - 01:00", title: "Krivi Put", subtitle: "House Music Therapy", location: "Smederevo", country: "RS", status: "past" },
  { id: "event-club-kult-2026", date: "2026-03-18", time: "21:00 - 22:00", title: "Club Kult", subtitle: "House Music Therapy", location: "Beograd", country: "RS", status: "past" },
  { id: "event-raybar-2026-mar", date: "2026-03-07", time: "20:00 - 01:00", title: "RayBar", subtitle: "House Music Therapy", location: "Novi Sad", country: "RS", status: "past" },
  { id: "event-raybar-2026", date: "2026-01-24", time: "", title: "RayBar", subtitle: "First Residency", location: "Novi Sad", country: "RS", status: "past" },
  { id: "event-charlie-bar-2026", date: "2026-01-10", time: "", title: "Charlie Bar", subtitle: "House Techno Session", location: "Smederevo", country: "RS", status: "past" },
  { id: "event-kult-2025", date: "2025-11-20", time: "", title: "Club Kult", subtitle: "House Groove Tech Set", location: "Belgrade", country: "RS", status: "past" },
  { id: "event-toucan-2025", date: "2025-08-19", time: "", title: "Toucan Nightclub", subtitle: "", location: "Zakynthos", country: "GR", status: "past" },
  { id: "event-exit-dance-arena-2025", date: "2025-07-12", time: "", title: "Exit Festival — Dance Arena", subtitle: "First Dance Arena Set", location: "Novi Sad", country: "RS", status: "past" },
  { id: "event-exit-students-2025", date: "2025-07-12", time: "", title: "Exit Festival — Students Stage", subtitle: "Late-Night House Set", location: "Novi Sad", country: "RS", status: "past" },
  { id: "event-borisov-atelje-2024", date: "2024-09-07", time: "", title: "Borisov Atelje", subtitle: "", location: "Petrovaradin", country: "RS", status: "past" },
  { id: "event-capital-nightclub-2024", date: "2024-07-23", time: "", title: "Capital Night Club", subtitle: "", location: "Lefkada", country: "GR", status: "past" },
  { id: "event-exit-asfm-2024", date: "2024-07-12", time: "", title: "Exit Festival — AS FM Stage", subtitle: "First Major Festival Stage", location: "Novi Sad", country: "RS", status: "past" },
  { id: "event-kst-2024", date: "2024-04-09", time: "", title: "Klub Studenata Tehnike", subtitle: "", location: "Belgrade", country: "RS", status: "past" },
  { id: "event-kc-lab-2023", date: "2023-09-02", time: "", title: "Kulturni Centar LAB", subtitle: "Silent Disco Party", location: "Novi Sad", country: "RS", status: "past" },
  { id: "event-krivi-put-2022", date: "2022-07-30", time: "", title: "Cafe Krivi Put", subtitle: "First Public Party", location: "Smederevo", country: "RS", status: "past" },
];

const upcomingEvents = events.filter(e => e.status === 'upcoming');

const musicEventSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://zippydj.com/events#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://zippydj.com/" },
        { "@type": "ListItem", "position": 2, "name": "Events", "item": "https://zippydj.com/events" }
      ]
    },
    ...upcomingEvents.map(e => ({
      "@type": "MusicEvent",
      "@id": `https://zippydj.com/events#${e.id}`,
      "name": `${e.title} — ${e.subtitle || 'House Music Therapy'}`,
      "startDate": e.time ? `${e.date}T${e.time.split(' - ')[0]}:00` : e.date,
      "endDate": e.time && e.time.includes(' - ') ? `${e.date}T${e.time.split(' - ')[1]}:00` : undefined,
      "eventStatus": "https://schema.org/EventScheduled",
      "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
      "location": {
        "@type": "Place",
        "name": e.title,
        "address": {
          "@type": "PostalAddress",
          "addressLocality": e.location,
          "addressCountry": e.country
        }
      },
      "performer": {
        "@type": ["Person","MusicGroup"],
        "@id": "https://zippydj.com/#person",
        "name": "DJ Zippy",
        "alternateName": "Zippy"
      },
      "organizer": {
        "@type": "Organization",
        "@id": "https://zippydj.com/#organization",
        "name": "DJ Zippy"
      },
      "url": "https://zippydj.com/events",
      "image": "https://zippydj.com/images/dj-zippy-house-music-dj.webp",
      "description": `DJ Zippy (Zippy) performing live at ${e.title} in ${e.location}. House Music Therapy.`
    }))
  ]
};
---

<Layout
  title="DJ Zippy Events | Live Shows & Festival Performances"
  description="Explore DJ Zippy's live performances, festival appearances, and club nights across Serbia including Exit Festival and Belgrade events."
  activePage="events"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(musicEventSchema)} />

  <section id="upcoming" class="isolate relative bg-brand-black pt-24 sm:pt-28 pb-16 overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60vw] h-[60vw] bg-brand-orange/10 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="container mx-auto px-6 sm:px-8 lg:px-12 z-30 relative">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-gray-400">
          <li><a href="/" class="hover:text-brand-orange transition-colors">Home</a></li>
          <li><span class="mx-2">/</span></li>
          <li class="text-white">Events</li>
        </ol>
      </nav>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-2">DJ Zippy</h1>
      <h2 class="font-display font-black leading-tight mb-4 text-brand-orange">Live Events & Festival Performances</h2>
      <p class="text-gray-400 text-lg md:text-xl max-w-2xl mb-10">From intimate club nights to major festival stages. House Music Therapy live.</p>
      <div class="flex items-center gap-4 mb-6">
        <div class="w-2 h-8 bg-brand-orange"></div>
        <h3 class="font-display text-2xl md:text-3xl font-bold">Upcoming <span class="text-brand-orange">Events</span></h3>
      </div>
      <div id="upcoming-events-container" class="space-y-3"></div>
    </div>
  </section>

  <section id="past" class="isolate relative py-16 sm:py-20 bg-brand-black border-t border-white/5">
    <div class="container mx-auto px-6 sm:px-8 lg:px-12">
      <div class="flex items-center gap-4 mb-10">
        <div class="w-2 h-8 bg-white/30"></div>
        <h2 class="font-display text-3xl md:text-4xl font-bold">Past <span class="text-gray-400">Highlights</span></h2>
      </div>
      <div id="past-events-container" class="space-y-3"></div>
      <div class="mt-12 text-center">
        <a href="/" class="inline-flex items-center gap-2 text-gray-400 hover:text-brand-orange transition-colors">
          <i class="fa-solid fa-arrow-left"></i> Back to Homepage
        </a>
      </div>
    </div>
  </section>

  <script is:inline set:html={`window.zippyEvents = ${JSON.stringify(events)};`} />

  <script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    if (!window.zippyEvents) return;

    var upcomingContainer = document.getElementById('upcoming-events-container');
    if (upcomingContainer) {
      var upcoming = window.zippyEvents.filter(function(e) { return e.status === 'upcoming'; });
      upcoming.sort(function(a, b) { return new Date(a.date) - new Date(b.date); });
      var upHtml = '';
      upcoming.forEach(function(e) {
        var d = new Date(e.date);
        var day = String(d.getDate()).padStart(2, '0');
        var month = d.toLocaleString('en-US', { month: 'short' }).toUpperCase();
        var year = d.getFullYear();
        var timeStr = e.time ? ' \u00b7 ' + e.time : '';
        upHtml += '<article class="flex items-center gap-4 sm:gap-6 border-l-4 border-brand-orange bg-brand-gray rounded-r-lg p-4 hover:bg-white/5 transition-colors">' +
          '<div class="flex-shrink-0 text-center min-w-[4rem]">' +
          '<span class="block font-display font-bold text-brand-orange text-xl leading-none">' + day + '</span>' +
          '<span class="block text-xs text-gray-400 uppercase tracking-widest">' + month + '</span>' +
          '<span class="block text-xs text-gray-500">' + year + '</span>' +
          '</div>' +
          '<div class="w-px h-10 bg-white/10 flex-shrink-0"></div>' +
          '<div class="flex-1 min-w-0">' +
          '<h4 class="font-display font-bold text-white text-base sm:text-lg leading-tight">' + e.title + '</h4>' +
          '<p class="text-gray-400 text-sm"><i class="fa-solid fa-location-dot mr-1 text-brand-orange"></i>' + e.location + timeStr + '</p>' +
          '</div></article>';
      });
      upcomingContainer.innerHTML = upHtml || '<p class="text-gray-400">No upcoming events scheduled.</p>';
    }

    var pastContainer = document.getElementById('past-events-container');
    if (pastContainer) {
      var past = window.zippyEvents.filter(function(e) { return e.status === 'past'; });
      past.sort(function(a, b) { return new Date(b.date) - new Date(a.date); });
      var pastHtml = '';
      past.forEach(function(e) {
        var d = new Date(e.date);
        var day = String(d.getDate()).padStart(2, '0');
        var month = d.toLocaleString('en-US', { month: 'short' }).toUpperCase();
        var year = d.getFullYear();
        var subtitleStr = e.subtitle ? ' \u00b7 ' + e.subtitle : '';
        pastHtml += '<article class="flex items-center gap-4 sm:gap-6 border-l-2 border-brand-gray bg-brand-dark rounded-r-lg p-4 hover:border-white/30 transition-colors">' +
          '<div class="flex-shrink-0 text-center min-w-[4rem]">' +
          '<span class="block font-display font-bold text-gray-400 text-lg leading-none">' + day + '</span>' +
          '<span class="block text-xs text-gray-500 uppercase tracking-widest">' + month + '</span>' +
          '<span class="block text-xs text-gray-600">' + year + '</span>' +
          '</div>' +
          '<div class="w-px h-8 bg-white/5 flex-shrink-0"></div>' +
          '<div class="flex-1 min-w-0">' +
          '<h3 class="font-display font-bold text-gray-300 text-sm sm:text-base leading-tight">' + e.title + '</h3>' +
          '<p class="text-gray-500 text-xs sm:text-sm"><i class="fa-solid fa-location-dot mr-1"></i>' + e.location + subtitleStr + '</p>' +
          '</div></article>';
      });
      pastContainer.innerHTML = pastHtml;
    }
  });
  </script>
</Layout>
