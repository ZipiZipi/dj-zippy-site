---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { getMixes, MIX_PLATFORMS, mixIcon, mixFallbackIcon } from '../lib/content';

const db = (Astro.locals as any).runtime?.env?.DB;
const { all: mixes } = await getMixes(db);

const initialPlatform = 'youtube';

function ytId(link: string): string | null {
  const m = link.match(/(?:v=|youtu\.be\/|embed\/)([\w-]{11})/);
  return m ? m[1] : null;
}

// Build JSON-LD from the live data so it stays in sync with admin edits.
const mixSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "@id": "https://zippydj.com/mixes#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://zippydj.com/" },
        { "@type": "ListItem", "position": 2, "name": "Mixes", "item": "https://zippydj.com/mixes" }
      ]
    },
    {
      "@type": "CollectionPage",
      "@id": "https://zippydj.com/mixes#collection",
      "name": "DJ Zippy Mixes & Playlists",
      "description": "Complete collection of DJ Zippy's mixes and playlists across YouTube, MixCloud, Spotify, SoundCloud, and Deezer.",
      "about": { "@id": "https://zippydj.com/#person" }
    },
    ...mixes.filter(m => m.platform === 'youtube' && ytId(m.link)).map(m => ({
      "@type": "VideoObject",
      "@id": `https://zippydj.com/mixes#${m.slug}`,
      "name": `${m.title} — DJ Zippy`,
      "description": m.description,
      "thumbnailUrl": m.thumbnail || `https://img.youtube.com/vi/${ytId(m.link)}/maxresdefault.jpg`,
      "uploadDate": "2024-01-01T00:00:00+00:00",
      "embedUrl": `https://www.youtube.com/embed/${ytId(m.link)}`,
      "url": m.link,
      "publisher": { "@id": "https://zippydj.com/#organization" }
    })),
    ...mixes.filter(m => m.platform === 'spotify' || m.platform === 'deezer').map(m => ({
      "@type": "MusicPlaylist",
      "@id": `https://zippydj.com/mixes#${m.slug}`,
      "name": m.title,
      "description": m.description,
      "url": m.link,
      "creator": { "@id": "https://zippydj.com/#person" }
    }))
  ]
};
---

<Layout
  title="DJ Zippy Mixes | House Music Therapy Sessions & Playlists"
  description="Stream all DJ Zippy mixes and playlists. House Music Therapy sessions on YouTube, MixCloud, Spotify, SoundCloud, and Deezer. Deep house, tech house, and grooves from Belgrade."
  activePage="mixes"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(mixSchema)} />

  <section class="isolate relative min-h-[40vh] flex flex-col items-center justify-center bg-brand-black pt-24 sm:pt-28 pb-12 overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[60vw] h-[60vw] bg-brand-orange/10 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="container mx-auto px-6 sm:px-8 lg:px-12 text-center z-30">
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex justify-center items-center space-x-2 text-sm text-gray-400">
          <li><a href="/" class="hover:text-brand-orange transition-colors">Home</a></li>
          <li><span class="mx-2">/</span></li>
          <li class="text-white">Mixes</li>
        </ol>
      </nav>
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-4">Stream DJ Zippy</h1>
      <h2 class="font-display text-xl md:text-2xl lg:text-3xl font-bold text-brand-orange mb-4">All <span class="text-brand-orange">Mixes</span> & Playlists</h2>
      <p class="text-gray-400 text-lg md:text-xl max-w-2xl mx-auto mb-8">Every House Music Therapy session. YouTube, MixCloud, Spotify, SoundCloud, and Deezer.</p>
    </div>
  </section>

  <section id="all-mixes" class="isolate relative py-16 sm:py-20 bg-brand-dark border-t border-white/5">
    <div class="container mx-auto px-6 sm:px-8 lg:px-12">
      <div class="flex flex-wrap gap-2 sm:gap-4 mb-10" id="mixes-tabs" role="tablist" aria-label="Filter mixes by platform">
        {MIX_PLATFORMS.map(p => {
          const active = p.id === initialPlatform;
          return (
            <button id={`mixes-tab-${p.id}`} role="tab" aria-selected={active ? 'true' : 'false'} data-platform={p.id}
              class={`flex items-center gap-2 px-5 py-2.5 text-sm font-bold uppercase border-b-2 transition-colors ${active ? 'border-brand-orange text-white' : 'border-transparent text-gray-500 hover:text-white'}`}>
              <i class={p.icon}></i> {p.label}
            </button>
          );
        })}
      </div>
      <div id="mixes-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {mixes.map(m => (
          <div
            class={`mix-card group relative overflow-hidden rounded-xl border border-white/5 hover:border-brand-orange/50 transition-all duration-300 aspect-video cursor-pointer ${m.platform === initialPlatform ? '' : 'hidden'}`}
            data-platform={m.platform}
            data-link={m.link}
          >
            {m.thumbnail
              ? <img src={m.thumbnail} alt={m.alt} loading="lazy" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              : <div class="absolute inset-0 bg-gradient-to-br from-brand-gray to-brand-black flex items-center justify-center"><i class={`${mixFallbackIcon(m.platform)} text-6xl text-white/10`}></i></div>
            }
            {m.featured && <div class="absolute top-3 right-3 bg-brand-orange text-white text-xs font-bold px-2 py-1 rounded z-20">FEATURED</div>}
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5 z-10">
              <div class="text-xs text-brand-orange font-bold uppercase mb-1">{m.genre}</div>
              <h3 class="font-display text-base font-bold text-white leading-tight mb-3">{m.title}</h3>
              <a href={m.link} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-bold text-white hover:text-brand-orange transition-colors">
                <i class={mixIcon(m.platform)}></i> Listen Now
              </a>
            </div>
          </div>
        ))}
      </div>
      <p id="mixes-empty" class="hidden text-gray-400 text-center py-12">No mixes found.</p>
    </div>
  </section>

  <script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var cards = Array.prototype.slice.call(document.querySelectorAll('.mix-card'));
    var tabs = Array.prototype.slice.call(document.querySelectorAll('#mixes-tabs button'));
    var emptyMsg = document.getElementById('mixes-empty');
    if (!cards.length && !tabs.length) return;

    // Card click opens the link (ignore clicks on the inner anchor).
    cards.forEach(function(card) {
      card.addEventListener('click', function(e) {
        if (e.target.closest('a')) return;
        var link = card.getAttribute('data-link');
        if (link) window.open(link, '_blank', 'noopener,noreferrer');
      });
    });

    function setFilter(platform) {
      var shown = 0;
      cards.forEach(function(card) {
        var match = card.getAttribute('data-platform') === platform;
        card.classList.toggle('hidden', !match);
        if (match) shown++;
      });
      if (emptyMsg) emptyMsg.classList.toggle('hidden', shown !== 0);
      tabs.forEach(function(tab) {
        var match = tab.getAttribute('data-platform') === platform;
        tab.classList.toggle('border-brand-orange', match);
        tab.classList.toggle('text-white', match);
        tab.classList.toggle('border-transparent', !match);
        tab.classList.toggle('text-gray-500', !match);
        tab.setAttribute('aria-selected', match ? 'true' : 'false');
      });
    }

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() { setFilter(tab.getAttribute('data-platform')); });
    });
  });
  </script>
</Layout>
