      <form id="contact-form" name="contact" method="POST" class="space-y-4">
        <input type="hidden" name="access_key" value="53a011ae-cafe-4a90-b080-b4e4d5891262" />
        <input type="hidden" name="subject" value="DJ Zippy — Booking Request" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <input type="text" id="name" name="name" placeholder="Name" required
            class="w-full bg-transparent border-b border-white/15 pb-2 text-sm text-white placeholder-gray-500 focus:border-brand-orange focus:outline-none" />
          <input type="text" id="venue" name="venue" placeholder="Venue/Event" required
            class="w-full bg-transparent border-b border-white/15 pb-2 text-sm text-white placeholder-gray-500 focus:border-brand-orange focus:outline-none" />
        </div>

        <input type="email" id="email" name="email" placeholder="Email Address" required
          class="w-full bg-transparent border-b border-white/15 pb-2 text-sm text-white placeholder-gray-500 focus:border-brand-orange focus:outline-none" />

        <textarea id="message" name="message" rows="3" placeholder="Tell me about the gig..." required
          class="w-full bg-transparent border-b border-white/15 pb-2 text-sm text-white placeholder-gray-500 focus:border-brand-orange focus:outline-none resize-none"></textarea>

        <button type="submit"
          class="text-sm text-brand-orange font-bold uppercase tracking-widest border-b border-brand-orange hover:text-white hover:border-white transition-colors pb-1">
          Send Request
        </button>
      </form>
