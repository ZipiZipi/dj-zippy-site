          <a href="https://www.youtube.com/@zovumezippy/" target="_blank" rel="me noopener noreferrer" aria-label="YouTube"
            class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center hover:bg-brand-orange hover:text-white transition-all">
            <i class="fa-brands fa-youtube"></i>
          </a>
          <a href="https://open.spotify.com/user/31aj2g4yokqhpoxwkpo5odxegsle" target="_blank" rel="me noopener noreferrer" aria-label="Spotify"
