<footer id="contact" class="bg-brand-dark pt-16 sm:pt-20 pb-10 border-t border-white/10">
  <div class="container mx-auto px-6 sm:px-8 lg:px-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      <div>
        <h2 class="font-display text-4xl font-bold mb-6">Let's <span class="text-brand-orange">Connect</span></h2>
        <p class="text-gray-400 mb-8">
          Available for club bookings, private events, and festivals. <br />
          Bringing the House Music Therapy to your event.
        </p>

        <div class="space-y-4 mb-8">
          <a href="mailto:veljkoned@gmail.com" class="flex items-center gap-4 text-xl hover:text-brand-orange transition-colors">
            <i class="fa-regular fa-envelope text-brand-orange"></i> veljkoned@gmail.com
          </a>
          <a href="https://ra.co/dj/zippy-2" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 text-xl hover:text-brand-orange transition-colors">
            <i class="fa-solid fa-square-poll-vertical text-brand-orange"></i> Resident Advisor Profile
          </a>
        </div>

        <div class="flex gap-4 sm:gap-6 mt-8 flex-wrap justify-center">
          <a href="https://www.instagram.com/zovumezippy/" target="_blank" rel="me noopener noreferrer"
            class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-white/5 flex items-center justify-center hover:bg-brand-orange hover:text-white transition-all">
            <i class="fa-brands fa-instagram text-lg sm:text-xl"></i>
          </a>
          <a href="https://www.youtube.com/@zovumezippy/" target="_blank" rel="me noopener noreferrer"
            class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-white/5 flex items-center justify-center hover:bg-brand-orange hover:text-white transition-all">
            <i class="fa-brands fa-youtube text-lg sm:text-xl"></i>
          </a>
          <a href="https://open.spotify.com/user/31aj2g4yokqhpoxwkpo5odxegsle" target="_blank" rel="me noopener noreferrer"
            class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-white/5 flex items-center justify-center hover:bg-brand-orange hover:text-white transition-all">
            <i class="fa-brands fa-spotify text-lg sm:text-xl"></i>
          </a>
          <a href="https://www.mixcloud.com/zovumezippy/" target="_blank" rel="me noopener noreferrer"
            class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-white/5 flex items-center justify-center hover:bg-brand-orange hover:text-white transition-all">
            <i class="fa-brands fa-mixcloud text-lg sm:text-xl"></i>
          </a>
          <a href="https://www.deezer.com/en/profile/2582254702" target="_blank" rel="me noopener noreferrer"
            class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-white/5 flex items-center justify-center hover:bg-brand-orange hover:text-white transition-all">
            <i class="fa-brands fa-deezer text-lg sm:text-xl"></i>
          </a>
        </div>
      </div>

      <form id="contact-form" name="contact" method="POST" class="space-y-6">
        <input type="hidden" name="access_key" value="53a011ae-cafe-4a90-b080-b4e4d5891262" />
        <input type="hidden" name="subject" value="DJ Zippy — Booking Request" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <input type="text" id="name" name="name" placeholder="Name" required
              class="w-full bg-transparent border-b border-white/15 pb-2 text-white placeholder-gray-500 focus:border-brand-orange focus:outline-none" />
          </div>
          <div>
            <input type="text" id="venue" name="venue" placeholder="Venue/Event" required
              class="w-full bg-transparent border-b border-white/15 pb-2 text-white placeholder-gray-500 focus:border-brand-orange focus:outline-none" />
          </div>
        </div>

        <div>
          <input type="email" id="email" name="email" placeholder="Email Address" required
            class="w-full bg-transparent border-b border-white/15 pb-2 text-white placeholder-gray-500 focus:border-brand-orange focus:outline-none" />
        </div>

        <div>
          <textarea id="message" name="message" rows="4" placeholder="Tell me about the gig..." required
            class="w-full bg-transparent border-b border-white/15 pb-2 text-white placeholder-gray-500 focus:border-brand-orange focus:outline-none resize-none"></textarea>
        </div>

        <div class="pt-2">
          <button type="submit"
            class="text-brand-orange font-bold uppercase tracking-widest border-b border-brand-orange hover:text-white hover:border-white transition-colors pb-1">
            Send Request
          </button>
        </div>
      </form>
    </div>

    <div class="mt-20 pt-8 border-t border-white/5 text-center text-gray-600 text-sm">
      &copy; 2025 DJ Zippy. All Rights Reserved. House Music Therapy.
      <span class="mx-2">|</span>
      <a href="/links" class="hover:text-brand-orange transition-colors">All Links &rarr;</a>
    </div>
  </div>
</footer>

<script>
  function initContactForm() {
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form && !form.dataset.bound) {
    form.dataset.bound = '1';
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const btn = this.querySelector('button[type="submit"]') as HTMLButtonElement;
      const orig = btn.innerText;
      btn.disabled = true;
      btn.innerText = 'Sending...';
      fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(new FormData(this))),
      })
      .then(res => {
        btn.innerText = res.ok ? 'Sent ✓' : 'Error — try veljkoned@gmail.com';
        if (res.ok) form.reset();
      })
      .catch(() => { btn.innerText = 'Error — try veljkoned@gmail.com'; })
      .finally(() => {
        setTimeout(() => { btn.disabled = false; btn.innerText = orig; }, 4000);
      });
    });
  }
  }
  document.addEventListener('astro:page-load', initContactForm);
</script>
