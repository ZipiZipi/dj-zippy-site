          <a href="mailto:veljkoned@gmail.com?subject=DJ%20Zippy%20%E2%80%94%20Press%20%2F%20EPK" data-track="contact_press" class="flex items-center gap-3 hover:text-brand-orange transition-colors">
            <span class="text-[10px] font-bold uppercase tracking-widest text-gray-500 w-20 flex-shrink-0">Press</span> veljkoned@gmail.com
          </a>
          <a href="https://ra.co/dj/zippy-2" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 hover:text-brand-orange transition-colors">
            <span class="text-[10px] font-bold uppercase tracking-widest text-gray-500 w-20 flex-shrink-0">RA</span> Resident Advisor Profile
          </a>
        </div>

        <div class="flex gap-2.5 flex-wrap">
          <a href="https://www.instagram.com/zovumezippy/" target="_blank" rel="me noopener noreferrer" aria-label="Instagram"
