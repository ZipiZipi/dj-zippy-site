---
// "One Record, Every Horizon" — the WORLD layer.
// A fixed, full-viewport stack of five code-drawn landscapes plus the traveling
// vinyl record. The real homepage sections (brand, collection, events, lead
// magnet, booking) scroll OVER this world; each section's arrival scrubs the
// crossfade to its scene and moves the record. So the story runs through every
// section, not just a hero. Video swap-in plan: docs/one-record-every-horizon.md

// Deterministic star field (x%, y%, twinkle delay s, scale)
const STARS: Array<[number, number, number, number]> = [
  [6, 12, 0.0, 1], [14, 28, 1.2, 0.7], [22, 8, 2.1, 1.2], [31, 22, 0.6, 0.8],
  [38, 14, 1.8, 1], [47, 6, 0.3, 0.7], [55, 18, 2.4, 1.1], [63, 10, 1.0, 0.8],
  [71, 24, 0.2, 1], [78, 7, 1.5, 0.7], [86, 16, 2.7, 1.2], [93, 26, 0.9, 0.8],
  [11, 42, 1.4, 0.6], [27, 38, 0.5, 0.7], [69, 36, 2.0, 0.6], [89, 40, 1.1, 0.7],
];
---

<div id="journey-world" class="j-world" aria-hidden="true">

  <!-- Scene 0: night / eclipse (base) -->
  <div class="j-scene j-ecl" data-s="ecl">
    <div class="j-stars">
      {STARS.map(([x, y, d, s]) => <i style={`left:${x}%;top:${y}%;animation-delay:${d}s;transform:scale(${s})`}></i>)}
    </div>
  </div>

  <!-- Scene 1: canyon = festival -->
  <div class="j-scene j-can" data-s="can">
    <div class="j-can-sky"></div>
    <div class="j-can-haze"></div>
    <div class="j-ray j-ray-a"></div>
    <div class="j-ray j-ray-b"></div>
    <svg class="j-layer" data-depth="0.8" viewBox="0 0 100 100" preserveAspectRatio="none"><path fill="#230e05" d="M0 62 C 10 54 16 60 26 50 C 34 44 40 56 50 48 C 60 42 66 54 76 46 C 84 40 92 52 100 46 V100 H0 Z"/></svg>
    <svg class="j-layer" data-depth="1.6" viewBox="0 0 100 100" preserveAspectRatio="none"><path fill="#150904" d="M0 74 C 12 62 20 70 30 58 C 40 48 48 64 58 54 C 70 44 78 62 88 52 C 94 46 98 56 100 52 V100 H0 Z"/></svg>
    <svg class="j-layer" data-depth="2.6" viewBox="0 0 100 100" preserveAspectRatio="none"><path fill="#0a0402" d="M0 88 C 14 74 24 84 36 70 C 46 60 56 76 68 64 C 78 56 88 72 100 62 V100 H0 Z"/></svg>
    <div class="j-parts j-dustp">{Array.from({ length: 6 }).map(() => <span></span>)}</div>
  </div>

  <!-- Scene 2: night forest = club -->
  <div class="j-scene j-for" data-s="for">
    <div class="j-for-sky"></div>
    <div class="j-canopy"></div>
    <svg class="j-layer" data-depth="0.9" viewBox="0 0 100 100" preserveAspectRatio="none">
      <g fill="#0e0804">
        <polygon points="6,100 6.9,0 8.1,0 9,100"/><polygon points="17,100 17.6,0 18.6,0 19.2,100"/>
        <polygon points="29,100 30,0 31.6,0 32.6,100"/><polygon points="43,100 43.7,0 44.9,0 45.6,100"/>
        <polygon points="58,100 58.9,0 60.3,0 61.2,100"/><polygon points="71,100 71.5,0 72.5,0 73,100"/>
        <polygon points="83,100 83.9,0 85.5,0 86.4,100"/><polygon points="94,100 94.6,0 95.7,0 96.3,100"/>
      </g>
    </svg>
    <div class="j-midfog"></div>
    <svg class="j-layer" data-depth="2.8" viewBox="0 0 100 100" preserveAspectRatio="none">
      <g fill="#040201">
        <polygon points="0,100 1.4,0 5.4,0 6.8,100"/><polygon points="20,100 21.6,0 26.4,0 28,100"/>
        <polygon points="48,100 49.2,0 53.2,0 54.4,100"/><polygon points="67,100 68.8,0 73.6,0 75.4,100"/>
        <polygon points="89,100 90.2,0 94.6,0 95.8,100"/>
      </g>
    </svg>
    <div class="j-fog"></div>
    <div class="j-parts j-flies">{Array.from({ length: 8 }).map(() => <span></span>)}</div>
  </div>

  <!-- Scene 3: open sea at dusk = bar / sunset set -->
  <div class="j-scene j-sea" data-s="sea">
    <div class="j-sea-sky"></div>
    <div class="j-sea-water" data-depth="0.6"></div>
    <div class="j-glint"></div>
    <div class="j-sea-reflect"></div>
    <svg class="j-wavehz" viewBox="0 0 1200 24" preserveAspectRatio="none">
      <path d="M0 12 Q 50 8 100 12 T 200 12 T 300 10 T 400 14 T 500 11 T 600 13 T 700 10 T 800 14 T 900 11 T 1000 13 T 1100 11 T 1200 12" fill="none" stroke="rgba(255,110,40,0.55)" stroke-width="2"/>
    </svg>
  </div>

  <!-- Scene 4: underwater = afterhours -->
  <div class="j-scene j-und" data-s="und">
    <div class="j-und-deep"></div>
    <div class="j-caustics"></div>
    <div class="j-shaft j-shaft-a" data-depth="0.8"></div>
    <div class="j-shaft j-shaft-b" data-depth="1.4"></div>
    <div class="j-parts j-bubs">{Array.from({ length: 9 }).map(() => <span></span>)}</div>
  </div>

  <!-- Scene 5: summit above the clouds = dawn -->
  <div class="j-scene j-sum" data-s="sum">
    <div class="j-sum-sky"></div>
    <div class="j-stars j-stars-fade">
      {STARS.slice(0, 9).map(([x, y, d, s]) => <i style={`left:${x}%;top:${y * 0.8}%;animation-delay:${d}s;transform:scale(${s})`}></i>)}
    </div>
    <svg class="j-layer" data-depth="0.5" viewBox="0 0 100 100" preserveAspectRatio="none"><path fill="#0e0605" d="M0 70 C 12 58 22 66 34 56 C 46 48 58 60 70 52 C 80 46 92 58 100 52 V100 H0 Z" opacity="0.8"/></svg>
    <div class="j-cloud j-cloud-a" data-depth="0.7"></div>
    <div class="j-cloud j-cloud-b" data-depth="1.2"></div>
    <svg class="j-layer" data-depth="0.9" viewBox="0 0 100 100" preserveAspectRatio="none">
      <path fill="#050202" d="M8 100 L44 32 L50 27 L57 36 L66 31 L92 100 Z"/>
      <g class="j-deck">
        <rect x="45.5" y="24.4" width="9" height="2.4" rx="0.5" fill="#120b07"/>
        <circle cx="49.5" cy="24" r="1.8" fill="#1a0f08" stroke="#3a1c0b" stroke-width="0.35"/>
        <line x1="53.2" y1="22.4" x2="51.2" y2="24" stroke="#42200d" stroke-width="0.45" stroke-linecap="round"/>
      </g>
    </svg>
    <div class="j-cloud j-cloud-c" data-depth="2"></div>
    <div class="j-sun-overlay"></div>
  </div>

  <!-- The traveling record -->
  <div class="j-disc">
    <div class="j-disc-glow"></div>
    <div class="j-disc-core">
      <div class="j-disc-label"></div>
      <div class="j-disc-hole"></div>
    </div>
  </div>

  <!-- Cinematic vignette -->
  <div class="j-vignette"></div>

  <!-- Venue progress marks -->
  <div class="j-dots">
    {['I', 'II', 'III', 'IV', 'V'].map((n) => <span>{n}</span>)}
  </div>
</div>

<style is:global>
  .j-world { position: fixed; inset: 0; z-index: 0; pointer-events: none; background: #020202; }

  .j-scene { position: absolute; inset: 0; opacity: 0; visibility: hidden; }
  .j-scene.j-ecl { opacity: 1; visibility: visible; background: radial-gradient(120% 90% at 50% 110%, #120705 0%, #060304 45%, #020202 100%); }
  .j-layer { position: absolute; inset: -8% 0; width: 100%; height: 116%; }

  /* Story sections that float over the world */
  .j-chapter { position: relative; z-index: 10; }
  .j-chapter-head { text-align: center; margin-bottom: 2rem; }
  .j-kicker {
    display: block; color: rgba(255, 140, 70, 0.85);
    font-size: 0.6rem; font-weight: 700; letter-spacing: 0.45em; margin-bottom: 0.7rem;
  }
  .j-title {
    font-family: 'Unbounded', sans-serif; font-weight: 900;
    font-size: clamp(1.7rem, 4.5vw, 3rem); letter-spacing: 0.12em;
    color: #fff; text-shadow: 0 2px 24px rgba(0,0,0,0.7);
  }
  .j-title::after { content: ''; display: block; width: 56px; height: 2px; margin: 0.7rem auto 0; background: #FF5500; box-shadow: 0 0 10px rgba(255,85,0,0.8); }
  .j-sub { color: rgba(235, 225, 218, 0.85); font-size: clamp(0.95rem, 2vw, 1.15rem); text-shadow: 0 1px 12px rgba(0,0,0,0.8); margin-top: 0.6rem; }

  /* Brand opening (lives in the first chapter section) */
  .j-brand-kicker {
    color: rgba(255, 130, 60, 0.85); font-size: 0.62rem; font-weight: 700;
    letter-spacing: 0.5em; margin-bottom: 1.2rem;
  }
  .j-brand-h {
    font-family: 'Unbounded', sans-serif; font-weight: 900; color: #fff;
    font-size: clamp(3.2rem, 11vw, 8rem); line-height: 0.95;
    text-shadow: 0 2px 34px rgba(0, 0, 0, 0.55);
  }
  .j-brand-sub {
    font-family: 'Unbounded', sans-serif; font-weight: 900;
    font-size: clamp(1.1rem, 3.4vw, 2.6rem); letter-spacing: 0.02em;
    background: linear-gradient(90deg, #FF5500, #ffffff);
    -webkit-background-clip: text; background-clip: text; color: transparent;
    filter: drop-shadow(0 2px 16px rgba(0, 0, 0, 0.5));
  }
  .j-hint {
    color: rgba(255,255,255,0.4); font-size: 0.65rem; letter-spacing: 0.5em; font-weight: 700;
    animation: j-hintpulse 2.2s ease-in-out infinite;
  }
  @keyframes j-hintpulse { 0%, 100% { opacity: 0.35; transform: translateY(0); } 50% { opacity: 1; transform: translateY(-6px); } }

  /* Stars */
  .j-stars { position: absolute; inset: 0; }
  .j-stars i {
    position: absolute; width: 2px; height: 2px; border-radius: 50%;
    background: rgba(255, 235, 215, 0.9);
    box-shadow: 0 0 6px rgba(255, 200, 150, 0.7);
    animation: j-twinkle 3.4s ease-in-out infinite;
  }
  @keyframes j-twinkle { 0%, 100% { opacity: 0.25; } 50% { opacity: 1; } }

  /* Traveling record */
  .j-disc {
    position: absolute; left: 50%; top: 118%;
    width: clamp(120px, 17vw, 220px); height: clamp(120px, 17vw, 220px);
    margin-left: calc(clamp(120px, 17vw, 220px) / -2);
    z-index: 20;
  }
  .j-disc-core {
    position: absolute; inset: 0; border-radius: 50%;
    background:
      radial-gradient(circle at center, transparent 17%, #0c0c0c 18%),
      repeating-radial-gradient(circle at center, rgba(32,32,32,1) 0px, rgba(18,18,18,1) 1.5px, rgba(26,26,26,1) 3px),
      linear-gradient(135deg, #121212 0%, #090909 55%, #121212 100%);
    box-shadow: 0 0 0 2px rgba(255, 120, 50, 0.55), 0 0 28px rgba(255, 85, 0, 0.45), inset 0 0 50px rgba(0,0,0,0.85);
    animation: vinyl-spin 14s linear infinite;
  }
  .j-disc-label {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 34%; height: 34%; border-radius: 50%;
    background-image: url('/images/art/vinyl-label.webp');
    background-size: cover; background-position: center;
    box-shadow: 0 0 0 2px rgba(0,0,0,0.6);
  }
  .j-disc-hole {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 6%; height: 6%; border-radius: 50%; background: #000;
    box-shadow: inset 0 0 3px rgba(255,255,255,0.25);
  }
  .j-disc-glow {
    position: absolute; inset: -42%;
    background: radial-gradient(circle, rgba(255, 110, 30, 0.5), rgba(255, 85, 0, 0.16) 42%, transparent 70%);
    opacity: 0.45;
  }

  /* Canyon */
  .j-can-sky { position: absolute; inset: 0; background: linear-gradient(180deg, #070304 0%, #1c0a04 30%, #702a09 62%, #c45413 86%, #e8762a 100%); }
  .j-can-haze {
    position: absolute; left: 50%; top: 16%; width: 70vmin; height: 70vmin;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(255, 140, 60, 0.28), transparent 65%);
    filter: blur(6px);
  }
  .j-ray {
    position: absolute; top: -22%; left: 30%; width: 26vw; height: 95%;
    background: linear-gradient(180deg, rgba(255, 150, 70, 0.16), transparent 75%);
    transform-origin: 50% 0; filter: blur(8px);
  }
  .j-ray-a { transform: rotate(14deg); animation: j-sway 11s ease-in-out infinite alternate; }
  .j-ray-b { left: 56%; width: 18vw; transform: rotate(-12deg); animation: j-sway 14s ease-in-out infinite alternate-reverse; }
  @keyframes j-sway { from { rotate: -4deg; opacity: 0.7; } to { rotate: 5deg; opacity: 1; } }
  .j-dustp span {
    position: absolute; width: 4px; height: 4px; border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 190, 150, 0.85), rgba(255, 120, 40, 0) 70%);
    filter: blur(0.5px); opacity: 0;
    animation: dust-float 12s linear infinite;
  }
  .j-dustp span:nth-child(1) { left: 16%; bottom: 10%; }
  .j-dustp span:nth-child(2) { left: 31%; bottom: 22%; animation-delay: 2.5s; }
  .j-dustp span:nth-child(3) { left: 47%; bottom: 14%; animation-delay: 5s; }
  .j-dustp span:nth-child(4) { left: 61%; bottom: 26%; animation-delay: 1.2s; }
  .j-dustp span:nth-child(5) { left: 76%; bottom: 12%; animation-delay: 6.4s; }
  .j-dustp span:nth-child(6) { left: 88%; bottom: 20%; animation-delay: 3.7s; }

  /* Forest */
  .j-for-sky { position: absolute; inset: 0; background: radial-gradient(110% 80% at 50% 8%, #1f0e05 0%, #0a0503 45%, #030202 100%); }
  .j-canopy { position: absolute; inset: 0 0 60% 0; background: linear-gradient(180deg, rgba(2, 1, 1, 0.95), transparent); }
  .j-midfog {
    position: absolute; left: -10%; right: -10%; top: 38%; height: 26%;
    background: linear-gradient(180deg, transparent, rgba(255, 120, 50, 0.06) 50%, transparent);
    filter: blur(12px);
    animation: j-fogdrift 20s ease-in-out infinite alternate-reverse;
  }
  .j-fog {
    position: absolute; left: -10%; right: -10%; bottom: 0; height: 36%;
    background: linear-gradient(180deg, transparent, rgba(255, 130, 60, 0.10) 45%, rgba(20, 10, 5, 0.85));
    filter: blur(10px);
    animation: j-fogdrift 16s ease-in-out infinite alternate;
  }
  @keyframes j-fogdrift { from { transform: translateX(-2.5%); } to { transform: translateX(2.5%); } }
  .j-flies span {
    position: absolute; width: 5px; height: 5px; border-radius: 50%;
    background: radial-gradient(circle, #ffc89a, rgba(255, 110, 30, 0) 70%);
    animation: j-firefly 1.935s ease-in-out infinite; /* 124 BPM, 4-beat cycle */
  }
  .j-flies span:nth-child(1) { left: 14%; top: 38%; }
  .j-flies span:nth-child(2) { left: 26%; top: 62%; animation-delay: 0.48s; }
  .j-flies span:nth-child(3) { left: 38%; top: 30%; animation-delay: 0.97s; }
  .j-flies span:nth-child(4) { left: 52%; top: 70%; animation-delay: 1.45s; }
  .j-flies span:nth-child(5) { left: 63%; top: 44%; }
  .j-flies span:nth-child(6) { left: 74%; top: 58%; animation-delay: 0.97s; }
  .j-flies span:nth-child(7) { left: 86%; top: 34%; animation-delay: 0.48s; }
  .j-flies span:nth-child(8) { left: 45%; top: 52%; animation-delay: 1.45s; }
  @keyframes j-firefly { 0%, 100% { opacity: 0.12; transform: scale(0.8); } 12% { opacity: 1; transform: scale(1.35); } 30% { opacity: 0.25; transform: scale(0.9); } }

  /* Sea */
  .j-sea-sky { position: absolute; inset: 0 0 42% 0; background: linear-gradient(180deg, #070304 0%, #2a0f06 50%, #7c2e0a 85%, #c25c18 100%); }
  .j-sea-water {
    position: absolute; inset: 58% -5% 0 -5%;
    background:
      repeating-linear-gradient(178deg, rgba(255, 130, 50, 0.07) 0 2px, transparent 2px 9px),
      linear-gradient(180deg, #220e05 0%, #0a0403 60%, #030202 100%);
    animation: j-swell 7s ease-in-out infinite alternate;
  }
  @keyframes j-swell { from { transform: translateY(0); } to { transform: translateY(-1.6%); } }
  .j-glint {
    position: absolute; left: -30%; top: 57%; width: 60%; height: 5%;
    background: linear-gradient(90deg, transparent, rgba(255, 170, 90, 0.18), transparent);
    filter: blur(6px);
    animation: j-glint-sweep 9s ease-in-out infinite alternate;
  }
  @keyframes j-glint-sweep { from { transform: translateX(0); } to { transform: translateX(160%); } }
  .j-sea-reflect {
    position: absolute; left: 50%; top: 58%; bottom: 6%; width: clamp(60px, 8vw, 110px);
    transform: translateX(-50%);
    background: linear-gradient(180deg, rgba(255, 130, 50, 0.5), rgba(255, 90, 20, 0.08) 70%, transparent);
    filter: blur(7px);
    -webkit-mask-image: repeating-linear-gradient(180deg, black 0 5px, transparent 5px 9px);
    mask-image: repeating-linear-gradient(180deg, black 0 5px, transparent 5px 9px);
  }
  .j-wavehz { position: absolute; left: 0; right: 0; top: 57.2%; height: 14px; width: 100%; }

  /* Underwater */
  .j-und-deep { position: absolute; inset: 0; background: radial-gradient(120% 95% at 50% 110%, #2e1407 0%, #130804 40%, #040203 80%); }
  .j-caustics {
    position: absolute; inset: -10%;
    background:
      repeating-radial-gradient(ellipse 60% 40% at 30% 20%, rgba(255, 150, 80, 0.05) 0 2%, transparent 4% 9%),
      repeating-radial-gradient(ellipse 50% 35% at 70% 30%, rgba(255, 120, 60, 0.04) 0 2%, transparent 4% 11%);
    animation: j-caustic 13s ease-in-out infinite alternate;
    opacity: 0.8;
  }
  @keyframes j-caustic { from { transform: translate(0, 0) scale(1); } to { transform: translate(2%, 3%) scale(1.06); } }
  .j-shaft {
    position: absolute; top: -12%; width: 16vw; height: 80%;
    background: linear-gradient(180deg, rgba(255, 150, 80, 0.13), transparent 80%);
    filter: blur(9px); transform: skewX(-14deg);
  }
  .j-shaft-a { left: 24%; }
  .j-shaft-b { left: 58%; width: 11vw; transform: skewX(11deg); }
  .j-bubs span {
    position: absolute; bottom: -5%; width: 7px; height: 7px; border-radius: 50%;
    border: 1px solid rgba(255, 170, 110, 0.5);
    background: radial-gradient(circle at 35% 30%, rgba(255, 200, 150, 0.5), rgba(255, 130, 60, 0.05) 70%);
    animation: j-bubble 8s linear infinite;
  }
  .j-bubs span:nth-child(1) { left: 12%; animation-duration: 9s; }
  .j-bubs span:nth-child(2) { left: 22%; animation-delay: 2s; width: 5px; height: 5px; }
  .j-bubs span:nth-child(3) { left: 34%; animation-delay: 4.5s; animation-duration: 11s; }
  .j-bubs span:nth-child(4) { left: 47%; animation-delay: 1s; width: 9px; height: 9px; }
  .j-bubs span:nth-child(5) { left: 56%; animation-delay: 5.5s; width: 5px; height: 5px; }
  .j-bubs span:nth-child(6) { left: 66%; animation-delay: 3s; animation-duration: 10s; }
  .j-bubs span:nth-child(7) { left: 76%; animation-delay: 6.5s; }
  .j-bubs span:nth-child(8) { left: 86%; animation-delay: 0.5s; width: 5px; height: 5px; }
  .j-bubs span:nth-child(9) { left: 93%; animation-delay: 4s; animation-duration: 12s; }
  @keyframes j-bubble {
    0% { transform: translate(0, 0); opacity: 0; }
    10% { opacity: 0.8; }
    50% { transform: translate(8px, -46vh); }
    95% { opacity: 0.25; }
    100% { transform: translate(-6px, -92vh); opacity: 0; }
  }

  /* Summit */
  .j-sum-sky { position: absolute; inset: 0; background: linear-gradient(180deg, #08040a 0%, #1c0a08 42%, #4a1a08 76%, #8a3a10 100%); }
  .j-stars-fade { opacity: 0.5; }
  .j-cloud {
    position: absolute; left: -12%; right: -12%; height: 22%;
    background: radial-gradient(45% 95% at 30% 50%, rgba(255, 150, 90, 0.13), transparent 70%),
                radial-gradient(38% 90% at 68% 45%, rgba(255, 120, 60, 0.10), transparent 70%);
    filter: blur(14px);
  }
  .j-cloud-a { top: 52%; animation: j-fogdrift 18s ease-in-out infinite alternate; }
  .j-cloud-b { top: 64%; animation: j-fogdrift 14s ease-in-out infinite alternate-reverse; }
  .j-cloud-c { top: 76%; height: 30%; filter: blur(18px); }
  .j-sun-overlay {
    --jsun: 0%;
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 0%, rgba(255, 110, 30, 0.0) 30%, rgba(255, 120, 40, 0.35) 70%, rgba(255, 170, 90, 0.55) 100%);
    background-size: 100% 300%;
    background-position: 50% var(--jsun);
    mix-blend-mode: screen; pointer-events: none;
  }

  .j-vignette {
    position: absolute; inset: 0; z-index: 22;
    background: radial-gradient(120% 120% at 50% 45%, transparent 55%, rgba(0, 0, 0, 0.5) 100%);
  }

  /* Venue progress marks */
  .j-dots {
    position: absolute; right: 4.5%; top: 50%; transform: translateY(-50%);
    display: flex; flex-direction: column; gap: 1.1rem; z-index: 30;
  }
  .j-dots span {
    font-family: 'Unbounded', sans-serif; font-size: 0.6rem; font-weight: 700;
    color: rgba(255, 255, 255, 0.22); text-align: center;
    transition: color 0.4s, transform 0.4s, text-shadow 0.4s;
  }
  .j-dots span.on {
    color: #FF5500; transform: scale(1.45);
    text-shadow: 0 0 12px rgba(255, 85, 0, 0.8);
  }
  @media (max-width: 640px) { .j-dots { right: 3%; gap: 0.8rem; } }

  /* Reduced motion: no moving world — sections stand on plain black */
  html.reduce-motion .j-world { display: none; }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  // Each chapter section (.j-chapter[data-scene]) scrubs the world to its scene
  // as it scrolls into view, and parks the record at its scene position.
  const DISC: Record<string, Record<string, string | number>> = {
    can: { top: '22%', x: '0vw', scale: 1.08 },
    for: { top: '13%', x: '13vw', scale: 0.5 },
    sea: { top: '33%', x: '0vw', scale: 0.66 },
    und: { top: '58%', x: '0vw', scale: 0.5 },
    sum: { top: '15%', x: '-0.5vw', scale: 0.2 },
  };
  const GLOW: Record<string, number> = { can: 1, for: 0.5, sea: 0.6, und: 1, sum: 0.35 };

  function initWorld() {
    const world = document.getElementById('journey-world');
    if (!world || world.dataset.bound) return;
    world.dataset.bound = '1';
    if ((window as any).__motionOff()) return;

    gsap.registerPlugin(ScrollTrigger);
    const lenis = (window as any).__lenis;
    if (lenis && !(window as any).__lenisGsap) {
      (window as any).__lenisGsap = true;
      lenis.on('scroll', ScrollTrigger.update);
    }

    const chapters = Array.from(document.querySelectorAll<HTMLElement>('.j-chapter[data-scene]'));
    const dots = Array.from(document.querySelectorAll('.j-dots span'));
    const sceneEl = (k: string) => document.querySelector(`.j-scene[data-s="${k}"]`);
    let master: gsap.core.Timeline | null = null;

    // ONE master timeline over the whole page scroll. Every shared element
    // (scenes, disc, glow, sunrise) is animated only here, at positions derived
    // from each chapter's offset — no competing scrubbed tweens, clean reverse.
    function build() {
      if (master) { master.scrollTrigger?.kill(); master.kill(); master = null; }
      const vh = window.innerHeight;
      const total = document.documentElement.scrollHeight - vh;
      if (total <= 0) return;
      const pos = (px: number) => Math.max(0, Math.min(1, px / total));

      master = gsap.timeline({
        defaults: { ease: 'none' },
        scrollTrigger: {
          trigger: document.body, start: 0, end: total, scrub: 0.5,
          onUpdate(self) {
            // venue numerals: chapter whose center band we're in
            const y = self.scroll();
            let idx = -1;
            chapters.forEach((sec, i) => {
              if (i === 0) return;
              if (y >= sec.offsetTop - vh * 0.6 && y < sec.offsetTop + sec.offsetHeight - vh * 0.4) idx = i - 1;
            });
            dots.forEach((d, i) => d.classList.toggle('on', i === idx));
          },
        },
      });

      // Brand intro: record rises out of the dark, brand dissolves
      const brand = chapters[0];
      if (brand) {
        const bEnd = pos(brand.offsetHeight * 0.55);
        master.fromTo('.j-disc', { top: '118%' }, { top: '52%', duration: Math.max(bEnd, 0.01), ease: 'power1.out' }, 0);
        const brandInner = brand.querySelector('.j-brand-block');
        if (brandInner) master.to(brandInner, { autoAlpha: 0, scale: 0.93, filter: 'blur(8px)', duration: Math.max(bEnd * 0.9, 0.01), ease: 'power1.in' }, 0);
      }

      chapters.forEach((sec, i) => {
        if (i === 0) return;
        const key = sec.dataset.scene as string;
        const prevKey = chapters[i - 1].dataset.scene as string;
        const scene = sceneEl(key);
        if (!scene || key === prevKey || !master) return;

        const t0 = pos(sec.offsetTop - vh * 0.92);
        const t1 = pos(sec.offsetTop - vh * 0.25);
        const dur = Math.max(t1 - t0, 0.005);

        master.to(sceneEl(prevKey), { autoAlpha: 0, duration: dur }, t0)
              .to(scene, { autoAlpha: 1, duration: dur }, t0);
        if (DISC[key]) master.to('.j-disc', { ...DISC[key], duration: dur, ease: 'power1.inOut' }, t0);
        if (GLOW[key] !== undefined) master.to('.j-disc-glow', { opacity: GLOW[key], duration: dur }, t0);
        if (key === 'sum') master.to('.j-sun-overlay', { '--jsun': '88%', duration: dur }, t0 + dur * 0.2);
      });
    }

    // Per-scene parallax: each layer is touched by exactly one trigger — safe
    // to keep outside the master (element-based, auto-refreshes on resize).
    chapters.forEach((sec, i) => {
      if (i === 0) return;
      const scene = sceneEl(sec.dataset.scene as string);
      if (!scene) return;
      scene.querySelectorAll('[data-depth]').forEach((layer) => {
        const d = parseFloat((layer as HTMLElement).dataset.depth || '1');
        gsap.fromTo(layer, { yPercent: 3.5 * d }, {
          yPercent: -3.5 * d, ease: 'none',
          scrollTrigger: { trigger: sec, start: 'top bottom', end: 'bottom top', scrub: 0.5 },
        });
      });
    });

    build();
    // Section offsets are baked into the master — rebuild when layout changes.
    let rt: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => { clearTimeout(rt); rt = setTimeout(build, 300); });
  }

  document.addEventListener('astro:page-load', initWorld);
  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill());
  });
</script>
